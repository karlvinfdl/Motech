{% extends 'base.html.twig' %}

{% block title %}Fête des Licornes{% endblock %}

{% block body %}

<div class="landing-page1">

  <!-- ===================== -->
  <!-- ZONE DES ÎLES -->
  <!-- ===================== -->
  <section class="islands-zone1" aria-label="Jeux de la fête">

    <!-- ELODIE (bas) -->
    <a href="{{ path('app_coaster') }}" class="island1 elodie1">
      <img src="{{ asset('assets/images/ile-elodie1.png') }}" alt="Star Coaster">
    </a>

    <!-- CHEMIN -->
    <div class="island1 ile1-1">
      <img src="{{ asset('assets/images/ile1.png') }}" alt="">
    </div>

    <div class="island1 ile2-1">
      <img src="{{ asset('assets/images/ile2.png') }}" alt="">
    </div>

    <!-- KARLVIN -->
    <a href="{{ path('app_scrabble') }}" class="island1 karlvin1">
      <img src="{{ asset('assets/images/ile-karlvin1.png') }}" alt="Scrabble des licornes">
    </a>

    <!-- CHEMIN -->
    <div class="island1 ile3-1">
      <img src="{{ asset('assets/images/ile3.png') }}" alt="">
    </div>

    <div class="island1 ile4-1">
      <img src="{{ asset('assets/images/ile4.png') }}" alt="">
    </div>

    <div class="island1 ile5-1">
      <img src="{{ asset('assets/images/ile5.png') }}" alt="">
    </div>

    <!-- AXEL -->
    <a href="{{ path('app_wheel') }}" class="island1 axel1">
      <img src="{{ asset('assets/images/ile-axel1.png') }}" alt="Roue magique">
    </a>

    <!-- CHEMIN -->
    <div class="island1 ile6-1">
      <img src="{{ asset('assets/images/ile6.png') }}" alt="">
    </div>

    <!-- ALEXIS -->
    <a href="{{ path('app_devinelemot') }}" class="island1 alexis1">
      <img src="{{ asset('assets/images/ile-alexis1.png') }}" alt="Devine le mot">
    </a>

  </section>

  <!-- ===================== -->
  <!-- COLONNE DROITE -->
  <!-- ===================== -->
  <aside class="right-col1">

    <!-- TITRE -->
    <section class="card1 card-title1">
      <h1 class="title1">
        Bienvenue à la<br>Fête des Licornes !
      </h1>
    </section>

    <!-- FORMULAIRE -->
    <section class="card1 card-form1">
      <h2 class="subtitle1">Formulaire</h2>

      <form method="post" class="form1">

        <label class="field1">
          <span class="label-text1">Nom :</span>
          <input name="nom" type="text" required>
        </label>

        <label class="field1">
          <span class="label-text1">Prénom :</span>
          <input name="prenom" type="text" required>
        </label>

        <label class="field1">
          <span class="label-text1">Âge :</span>
          <input name="age" type="number" min="0" max="120" required>
        </label>

        <label class="field1">
          <span class="label-text1">Email :</span>
          <input name="email" type="email" required>
        </label>

        <label class="field1">
          <span class="label-text1">Ville :</span>
          <input name="ville" type="text" required>
        </label>

        <button class="btn1" type="submit">
          Envoyer
        </button>

      </form>
    </section>

    <!-- BOUTON ÉQUIPE -->
    <a href="{{ path('app_equipe') }}" class="big-btn1">
      Découvrir l’équipe
    </a>

    <!-- EASTER EGG -->
    <section class="card1 card-egg1">
      <div class="egg1">

        <img src="{{ asset('assets/images/tokyo.png') }}" alt="Tokyo">

        <div class="egg-text1">
          <h3 class="egg-title1">Easter egg</h3>
          <p class="egg-desc1">
            Je suis Tokyo aide moi à<br>
            retrouver ma famille
          </p>
        </div>

      </div>
    </section>

  </aside>

</div>

{% endblock %}
// Gestionnaire d'état de la musique courante
let currentMusic = null;

/**
 * Arrête proprement toutes les musiques de fond
 */
function stopAllMusic() {
    const musicIds = ['bgMusic', 'RulMusic', 'badgeMusic', 'scoreMusic', 'EndMusic',
                      'lvlMusicOne', 'lvlMusicTwo', 'lvlMusicThree'];
    musicIds.forEach(id => {
        const el = document.getElementById(id);
        if (el) {
            el.pause();
            el.currentTime = 0;
        }
    });
}

/**
 * Affiche une page et cache toutes les autres
 * Gère aussi les classes CSS de body pour les backgrounds
 * @param {string} pageId - L'ID de la div de la page à afficher
 */
function showPage(pageId) {
    // Cache toutes les pages
    document.querySelectorAll('.app-page').forEach(p => {
        p.style.display = 'none';
        p.classList.remove('active-page');
    });

    // Nettoie les classes de body liées aux mondes/pages
    document.body.classList.remove(
        'page-accueil_3', 'page-règles', 'badge-page', 'score-board',
        'ending-game', 'world_1', 'world_2', 'world_3', 'in-game'
    );

    const page = document.getElementById(pageId);
    if (!page) return;

    // ---- CORRECTION BUG 2 (suite) ----
    // Cache le welcomeOverlay sur toutes les pages sauf page-jeu (géré dans le case)
    const wOvHide = document.getElementById('welcomeOverlay');
    if (wOvHide && pageId !== 'page-jeu') wOvHide.style.display = 'none';

    page.style.display = '';
    page.classList.add('active-page');

    // Applique la classe body correspondante + logique d'entrée de page
    switch (pageId) {
        case 'page-accueil':
            document.body.classList.add('page-accueil_3');
            document.getElementById('homeSettingsBtn').style.display = '';
            initAccueil();
            break;

        case 'page-regles':
            document.body.classList.add('page-règles');
            document.getElementById('homeSettingsBtn').style.display = '';
            initRegles();
            break;

        case 'page-badges':
            document.body.classList.add('badge-page');
            document.getElementById('homeSettingsBtn').style.display = '';
            initBadges();
            break;

        case 'page-jeu':
            document.body.classList.add('world_1', 'in-game');
            document.getElementById('homeSettingsBtn').style.display = 'none';
            // ---- CORRECTION BUG 3 ----
            // Affiche le welcomeOverlay avec display:flex explicite (il est hors de #page-jeu)
            const wOv = document.getElementById('welcomeOverlay');
            if (wOv) wOv.style.display = 'flex';
            initJeu();
            break;

        case 'page-scores':
            document.body.classList.add('score-board');
            document.getElementById('homeSettingsBtn').style.display = '';
            initScores();
            break;

        case 'page-fin':
            document.body.classList.add('ending-game');
            document.getElementById('homeSettingsBtn').style.display = '';
            initFin();
            break;
    }
}

// ============================================================
// BLOC JS 3 : SYSTÈME GLOBAL DE BADGES (unlockBadge)
// Utilisé par toutes les pages
// ============================================================

function unlockBadge(badgeId) {
    let unlocked = JSON.parse(localStorage.getItem('unlockedBadges')) || [];
    let newBadges = JSON.parse(localStorage.getItem('newBadges')) || [];

    if (unlocked.includes(badgeId)) return;

    unlocked.push(badgeId);
    newBadges.push(badgeId);
    localStorage.setItem('unlockedBadges', JSON.stringify(unlocked));
    localStorage.setItem('newBadges', JSON.stringify(newBadges));

    const badge = badgeData.find(b => b.id === badgeId);
    if (!badge) return;

    // Son du badge
    const sound = document.getElementById('badgeSound');
    if (sound) {
        sound.currentTime = 0;
        sound.volume = parseFloat(localStorage.getItem('sfxVol') || 0.7);
        sound.play().catch(e => console.log('Badge audio bloqué:', e));
    }

    // Notification visuelle style PS5
    const container = document.getElementById('badgeNotificationContainer');
    if (container) {
        const notif = document.createElement('div');
        notif.className = 'badge-notification';
        notif.innerHTML = `
            <div class="badge-icon-notify"><img src="${badge.img}" alt="Icon"></div>
            <div class="badge-info-notify">
                <p class="title-notif">Badge Débloqué !</p>
                <p class="name-notif">${badge.name}</p>
            </div>`;

        let duration = 2000;
        if (container.querySelectorAll('.badge-notification').length > 2) duration = 1500;

        container.appendChild(notif);
        setTimeout(() => notif.classList.add('show'), 100);
        setTimeout(() => {
            notif.classList.remove('show');
            setTimeout(() => notif.remove(), 500);
        }, duration);
    }

    // Vérification collection complète (Maître des Licornes)
    if (badgeId !== 'full_collection') {
        const allOtherBadges = badgeData.filter(b => b.id !== 'full_collection');
        const hasAllOthers = allOtherBadges.every(b => unlocked.includes(b.id));
        if (hasAllOthers) {
            setTimeout(() => unlockBadge('full_collection'), 2500);
        }
    }

    // Mise à jour des pastilles d'onglets si la page badges est active
    if (document.getElementById('page-badges').classList.contains('active-page')) {
        updateTabNotifications();
    }
}

// ============================================================
// BLOC JS 4 : PARAMÈTRES GLOBAUX (Settings overlay)
// ============================================================

const settingsOverlay = document.getElementById('settingsOverlay');
const homeSettingsBtn = document.getElementById('homeSettingsBtn');
const closeSettingsBtn = document.getElementById('closeSettingsBtn');
const musicSlider     = document.getElementById('musicVolume');
const sfxSlider       = document.getElementById('sfxVolume');

// Chargement initial des volumes
window.addEventListener('DOMContentLoaded', () => {
    const savedMusic = localStorage.getItem('musicVol') || 0.5;
    const savedSfx   = localStorage.getItem('sfxVol')   || 0.7;
    musicSlider.value = savedMusic;
    sfxSlider.value   = savedSfx;
});

// Bouton paramètres flottant
homeSettingsBtn.onclick = () => {
    settingsOverlay.style.display = 'flex';
    unlockBadge('settings_pro');
};

// Fermeture paramètres
closeSettingsBtn.onclick = () => {
    localStorage.setItem('musicVol', musicSlider.value);
    localStorage.setItem('sfxVol',   sfxSlider.value);
    // Applique le volume à la musique courante
    const allMusics = ['bgMusic','RulMusic','badgeMusic','scoreMusic','EndMusic',
                       'lvlMusicOne','lvlMusicTwo','lvlMusicThree'];
    allMusics.forEach(id => {
        const el = document.getElementById(id);
        if (el) el.volume = parseFloat(musicSlider.value);
    });
    settingsOverlay.style.display = 'none';
};

// Slider musique (temps réel)
musicSlider.oninput = () => {
    const vol = parseFloat(musicSlider.value);
    localStorage.setItem('musicVol', vol);
    const allMusics = ['bgMusic','RulMusic','badgeMusic','scoreMusic','EndMusic',
                       'lvlMusicOne','lvlMusicTwo','lvlMusicThree'];
    allMusics.forEach(id => {
        const el = document.getElementById(id);
        if (el && !el.paused) el.volume = vol;
    });
};

// Slider SFX
sfxSlider.oninput = () => {
    localStorage.setItem('sfxVol', sfxSlider.value);
};

// Initialisation stats localStorage
const statsKeys = ['totalYami','totalBombsIgnored','totalUfoCount','totalCloudsHit','totalBoshisCount','totalDogsCount'];
statsKeys.forEach(s => { if (!localStorage.getItem(s)) localStorage.setItem(s, 0); });

</script>


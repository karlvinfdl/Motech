   SEGMENT J : JAVASCRIPT — PARTIE 4 : LOGIQUE PAGE BADGES
   =========================================================================================================================== #}
<script>
// ============================================================
// BLOC JS 7 : PAGE BADGES (initBadges)
// ============================================================

function initBadges() {
    stopAllMusic();

    const badgeMusicEl = document.getElementById('badgeMusic');
    const savedVol = parseFloat(localStorage.getItem('musicVol') || 0.5);

    if (badgeMusicEl) {
        badgeMusicEl.volume = savedVol;
        badgeMusicEl.play().catch(() => {
            document.addEventListener('click', () => {
                if (badgeMusicEl.paused) badgeMusicEl.play();
            }, { once: true });
        });
    }

    const grid = document.getElementById('badgeGrid');
    const tabs = document.querySelectorAll('.tab');

    // --- Render grille de badges ---
    function renderBadges(categoryFilter) {
        if (!grid) return;
        grid.innerHTML = '';
        const unlockedBadges = JSON.parse(localStorage.getItem('unlockedBadges')) || [];
        const newBadges      = JSON.parse(localStorage.getItem('newBadges'))       || [];
        const sfxVol         = parseFloat(localStorage.getItem('sfxVol') || 0.7);

        const filtered = badgeData.filter(b => b.category === categoryFilter);

        filtered.forEach(badge => {
            const isUnlocked = unlockedBadges.includes(badge.id);
            const isNew      = newBadges.includes(badge.id);

            const item = document.createElement('div');
            item.className = `badge-item ${isUnlocked ? 'unlocked' : 'locked'} ${isUnlocked && isNew ? 'new-badge' : ''}`;

            item.innerHTML = isUnlocked
                ? `<img src="${badge.img}" alt="${badge.name}">`
                : `<div class="lock-icon">?</div>`;

            item.onclick = () => {
                const sndPath = isUnlocked ? ASSETS.sounds.openRules : ASSETS.sounds.blocked;
                const snd = new Audio(sndPath);
                snd.volume = sfxVol;
                snd.play();

                if (isUnlocked) {
                    showBadgeDetails(badge);
                    if (item.classList.contains('new-badge')) {
                        item.classList.remove('new-badge');
                        const currentNew = JSON.parse(localStorage.getItem('newBadges')) || [];
                        const updatedNew = currentNew.filter(id => id !== badge.id);
                        localStorage.setItem('newBadges', JSON.stringify(updatedNew));
                        updateTabNotifications();
                    }
                } else {
                    showBadgeDetails({ name: '???', desc: 'Contenu verrouillé. Continuez à jouer !', img: ASSETS.images.unknown });
                }
            };

            grid.appendChild(item);
        });
    }

    // --- Gestion des onglets ---
    tabs.forEach(tab => {
        tab.onclick = () => {
            const sfxVol = parseFloat(localStorage.getItem('sfxVol') || 0.7);
            const tabSnd = new Audio(ASSETS.sounds.tabsSound);
            tabSnd.volume = sfxVol;
            tabSnd.play();

            tabs.forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            tab.classList.remove('tab-notify');
            renderBadges(tab.textContent);
        };
    });

    // Initialisation avec l'onglet CoP
    renderBadges('CoP');
    updateTabNotifications();

    // --- Bouton RETOUR (vers accueil) ---
    const backBtn = document.getElementById('badgesBackBtn');
    if (backBtn) {
        backBtn.onclick = () => {
            const sfxVol = parseFloat(localStorage.getItem('sfxVol') || 0.7);
            const snd = new Audio(ASSETS.sounds.returnSnd);
            snd.volume = sfxVol;
            snd.play();
            backBtn.innerText = 'HOME...';
            backBtn.style.opacity = '0.6';

            if (badgeMusicEl) {
                const fadeOut = setInterval(() => {
                    if (badgeMusicEl.volume > 0.1) {
                        badgeMusicEl.volume -= 0.1;
                    } else {
                        badgeMusicEl.pause();
                        clearInterval(fadeOut);
                        backBtn.innerText = 'RETOUR';
                        backBtn.style.opacity = '';
                        showPage('page-accueil');
                    }
                }, 50);
            } else {
                setTimeout(() => {
                    backBtn.innerText = 'RETOUR';
                    backBtn.style.opacity = '';
                    showPage('page-accueil');
                }, 2000);
            }
        };
    }

    // --- Bouton JOUER AU JEU ---
    const goPlayBtn = document.getElementById('badgesGoPlayBtn');
    if (goPlayBtn) {
        goPlayBtn.onclick = (e) => {
            const sfxVol = parseFloat(localStorage.getItem('sfxVol') || 0.7);
            const snd = new Audio(ASSETS.sounds.gameEntry);
            snd.volume = sfxVol;
            snd.play();
            goPlayBtn.innerText = 'CHARGEMENT...';
            goPlayBtn.style.opacity = '0.6';

            if (badgeMusicEl) {
                const fadeOut = setInterval(() => {
                    if (badgeMusicEl.volume > 0.1) {
                        badgeMusicEl.volume -= 0.1;
                    } else {
                        badgeMusicEl.pause();
                        clearInterval(fadeOut);
                        goPlayBtn.innerText = 'JOUER AU JEU';
                        goPlayBtn.style.opacity = '';
                        showPage('page-regles');
                    }
                }, 200);
            } else {
                setTimeout(() => {
                    goPlayBtn.innerText = 'JOUER AU JEU';
                    goPlayBtn.style.opacity = '';
                    showPage('page-regles');
                }, 200);
            }
        };
    }
}

/**
 * Affiche les détails d'un badge dans la carte latérale
 */
function showBadgeDetails(badge) {
    const detailImg  = document.getElementById('detailImg');
    const detailName = document.getElementById('detailName');
    const detailDesc = document.getElementById('detailDesc');

    if (!detailImg) return;

    const photoContainer = detailImg.parentElement;

    detailImg.src       = badge.img;
    detailName.textContent = badge.name;
    detailDesc.textContent = badge.desc;

    if (badge.img === ASSETS.images.unknown) {
        photoContainer.style.backgroundColor = '#ffffff';
        photoContainer.classList.remove('unlocked-photo-bg');
    } else {
        photoContainer.style.backgroundColor = '';
        photoContainer.classList.add('unlocked-photo-bg');
    }
}

/**
 * Met à jour les pastilles rouges sur les onglets
 */
function updateTabNotifications() {
    const newBadges = JSON.parse(localStorage.getItem('newBadges')) || [];
    const tabs = document.querySelectorAll('#page-badges .tab');

    tabs.forEach(tab => {
        const category = tab.textContent;
        const hasNew = newBadges.some(badgeId => {
            const badge = badgeData.find(b => b.id === badgeId);
            return badge && badge.category === category;
        });
        if (hasNew) tab.classList.add('tab-notify');
        else        tab.classList.remove('tab-notify');
    });
}
</script>


        </div>
        <div class="click-to-continue">Appuyer sur Entree ou Espace pour continuer</div>
    </div>

    {# Overlay Pause #}
    <div id="pauseOverlay" class="pause-overlay">
        <div class="pause-content">
            <h2 class="pause-title">PAUSE</h2>
            <div class="pause-buttons">
                <button id="resumeBtn"   class="btn-pause-menu">REPRENDRE</button>
                <button id="settingsBtn" class="btn-pause-menu">RÉGLAGES</button>
                <button id="quitBtn"     class="btn-pause-menu btn-quit">QUITTER</button>
            </div>
        </div>
    </div>

    {# Overlay confirmation quitter #}
    <div id="confirmOverlay" class="custom-overlay" style="display:none;">
        <div class="confirm-box">
            <p>QUITTER ?</p>
            <div class="confirm-buttons">
                <button id="confirmYes">OUI</button>
                <button id="confirmNo">ANNULER</button>
            </div>
        </div>
    </div>

    {# Message de reprise (countdown après pause) #}
    <div id="restartCountdown" class="restart-countdown"></div>

</div>{# /page-jeu #}

{# ===========================================================================================================================
   PAGE 5 : SCORES (#page-scores)
   Correspond à pages/scores.html d'origine
   =========================================================================================================================== #}

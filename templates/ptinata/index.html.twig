   SEGMENT I : JAVASCRIPT — PARTIE 3 : LOGIQUE PAGE RÈGLES
   =========================================================================================================================== #}
<script>
// ============================================================
// BLOC JS 6 : PAGE RÈGLES (initRegles)
// ============================================================

function initRegles() {
    stopAllMusic();

    const rulMusic       = document.getElementById('RulMusic');
    const clickRulesSound = document.getElementById('clickRules');
    const closeRulesSound = document.getElementById('closeRules');
    const openBtn        = document.getElementById('open-details');
    const modal          = document.getElementById('details-modal');
    const closeBtn       = document.getElementById('close-btn');
    const btnStart       = document.getElementById('btnStart');
    const lakituBtn      = document.getElementById('lakituBadgeBtn');
    const lakituImg      = document.getElementById('lakituImg');
    const evilSnd        = document.getElementById('evilSound');

    const getSavedMusicVol = () => parseFloat(localStorage.getItem('musicVol') || 0.5);
    const getSavedSfxVol   = () => parseFloat(localStorage.getItem('sfxVol')   || 0.7);

    // Reset icône Lakitu
    if (lakituImg) lakituImg.src = ASSETS.images.logoFavicon;
    if (lakituBtn) lakituBtn.classList.remove('evil');

    // --- Musique avec fade in ---
    const startRulMusic = () => {
        if (rulMusic && rulMusic.paused) {
            const targetVol = getSavedMusicVol();
            rulMusic.volume = 0;
            rulMusic.play().then(() => {
                const fadeIn = setInterval(() => {
                    if (rulMusic.volume < targetVol) {
                        rulMusic.volume = Math.min(targetVol, rulMusic.volume + 0.05);
                    } else {
                        clearInterval(fadeIn);
                    }
                }, 100);
                document.removeEventListener('click', startRulMusic);
            }).catch(e => console.log('Règles audio bloqué'));
        }
    };

    startRulMusic();
    document.addEventListener('click', startRulMusic);

    // --- Bouton Lakitu (Easter Egg → badges) ---
    if (lakituBtn) {
        lakituBtn.onclick = () => {
            unlockBadge('lakitu_clicker');

            if (rulMusic) { rulMusic.pause(); rulMusic.currentTime = 0; }

            const targetSound = evilSnd || clickRulesSound;
            if (targetSound) {
                targetSound.volume = getSavedSfxVol();
                targetSound.currentTime = 0;
                targetSound.play();
            }

            if (lakituImg) lakituImg.src = ASSETS.images.evilLakituPng;
            if (lakituBtn) lakituBtn.classList.add('evil');

            document.removeEventListener('click', startRulMusic);
            document.removeEventListener('keydown', handleReglesKeydown);

            setTimeout(() => {
                showPage('page-badges');
            }, 3000);
        };
    }

    // --- Modale Détails Items ---
    if (openBtn) {
        openBtn.onclick = (e) => {
            unlockBadge('fast_check');
            if (clickRulesSound) {
                clickRulesSound.volume = getSavedSfxVol();
                clickRulesSound.currentTime = 0;
                clickRulesSound.play();
            }
            modal.classList.add('active');
        };
    }

    if (closeBtn) {
        closeBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            if (closeRulesSound) {
                closeRulesSound.volume = getSavedSfxVol();
                closeRulesSound.currentTime = 0;
                closeRulesSound.play();
            }
            modal.classList.remove('active');
        });
    }

    if (modal) {
        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                if (closeRulesSound) {
                    closeRulesSound.volume = getSavedSfxVol();
                    closeRulesSound.currentTime = 0;
                    closeRulesSound.play();
                }
                modal.classList.remove('active');
            }
        });
    }

    // --- Bouton continuer (vers jeu) ---
    const leavePage = () => {
        if (btnStart && btnStart.classList.contains('leaving')) return;
        if (settingsOverlay.style.display === 'flex') return;
        if (modal && modal.classList.contains('active')) return;

        if (btnStart) btnStart.classList.add('leaving');
        document.removeEventListener('click', startRulMusic);
        document.removeEventListener('keydown', handleReglesKeydown);

        if (rulMusic) {
            const fadeOut = setInterval(() => {
                if (rulMusic.volume > 0.1) {
                    rulMusic.volume -= 0.1;
                } else {
                    clearInterval(fadeOut);
                    rulMusic.pause();
                    if (btnStart) btnStart.classList.remove('leaving');
                    showPage('page-jeu');
                }
            }, 50);
        } else {
            showPage('page-jeu');
        }
    };

    if (btnStart) btnStart.onclick = leavePage;

    document.addEventListener('keydown', handleReglesKeydown);

    function handleReglesKeydown(e) {
        const currentPage = document.querySelector('.app-page.active-page');
        if (!currentPage || currentPage.id !== 'page-regles') {
            document.removeEventListener('keydown', handleReglesKeydown);
            return;
        }
        const isModalOpen    = modal && modal.classList.contains('active');
        const isSettingsOpen = settingsOverlay.style.display === 'flex';
        if ((e.key === 'Enter' || e.key === ' ') && !isModalOpen && !isSettingsOpen) {
            leavePage();
        }
    }
}
</script>


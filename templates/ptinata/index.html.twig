        </div>
    </div>

</div>{# /page-fin #}


{# ===========================================================================================================================
   SEGMENT F : STYLES INLINE — Gestion SPA (Single Page Application)
   Ces styles s'ajoutent à ceux du fichier style.css existant
   =========================================================================================================================== #}
<style>
/* --- Gestion des pages (SPA) --- */
.app-page {
    display: none;
    width: 100%;
    min-height: 100vh;
    position: relative;
}

.app-page.active-page {
    display: flex !important;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

/* La page jeu doit être position:fixed pour bloquer le scroll */
#page-jeu.active-page {
    display: block !important;
    position: fixed;
    inset: 0;
    overflow: hidden;
}

/* La page scores nécessite un display:block pour son layout */
#page-scores.active-page {
    display: block !important;
}

/* La page fin */
#page-fin.active-page {
    display: flex !important;
    justify-content: center;
    align-items: center;
}

/* La page badges */
#page-badges.active-page {
    display: flex !important;
    justify-content: center;
    align-items: center;
}

/* La page règles */
#page-regles.active-page {
    display: flex !important;
    justify-content: center;
    align-items: center;
}

/* Override body pour les pages qui ont leur propre body class dans l'original */
/* Ces classes sont appliquées dynamiquement par JS sur #page-jeu */
body.world_1 #page-jeu,
body.world_2 #page-jeu,
body.world_3 #page-jeu {
    background-attachment: fixed;
}

/* Paramètres (modal global) — s'assure qu'il passe devant tout */
#settingsOverlay {
    z-index: 70000 !important;
}

/* Bouton floating settings — visible sur toutes les pages sauf le jeu actif */
#homeSettingsBtn {
    z-index: 70000;
}

/* Masquer le bouton paramètres flottant pendant le jeu (le menu pause gère ça) */
body.in-game #homeSettingsBtn {
    display: none !important;
}


/* Bouton jouer au jeu dans la page badges */
#badgesGoPlayBtn {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    max-width: 350px;
    height: 60px;
    background-color: #f5c2cf;
    color: rgb(0, 0, 0);
    text-decoration: none;
    font-family: 'Arial Black', sans-serif;
    border: 3px solid #000000;
    border-radius: 8px;
    box-shadow: 0 4px 0 #f5c2cf;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 16px;
    font-weight: 900;
}

#badgesGoPlayBtn:hover {
    background-color: #ff0000;
    color: #000;
    border-color: #ffffff;
    box-shadow: 0 6px 0 #cc0000;
    transform: translateY(-3px);
}

/* Paramètres dans la page règles */
.setting-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 15px;
    margin-bottom: 15px;
}

    /* 1. ON ARRACHE LA MODALE DU FLUX FLEXBOX DU BODY */
    .ck-modal {
        display: none; /* Le JS gère l'affichage en flex */
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        right: 0 !important;
        bottom: 0 !important;
        width: 100vw !important;
        height: 100vh !important;
        margin: 0 !important;
        padding: 0 !important;
        
        /* INDISPENSABLE : On dit au navigateur d'ignorer le flex du body */
        flex: none !important;
        align-self: auto !important;
        
        /* On passe devant absolument tout (Wii, Notebook, Lakitu) */
        z-index: 2147483647 !important;
        background: rgba(0, 0, 0, 0.85) !important;
        
        /* Centrage parfait */
        align-items: center !important;
        justify-content: center !important;
    }

    /* 2. ON FORCE LE CONTENU À RESTER AU CENTRE ET À NE PAS ÊTRE ÉCRASÉ */
    .ck-modal__box {
        position: relative !important;
        z-index: 2147483648 !important;
        margin: auto !important;
        display: block !important;
        width: 90% !important;
        max-width: 520px !important;

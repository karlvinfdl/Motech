{% extends 'base.html.twig' %}

{% block title %}Pinata{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/styles/app-kyl.css') }}">
{% endblock %}

{% block body %}

{# ======================================================================
   SEGMENT A : ASSETS AUDIO GLOBAUX (partagés entre toutes les sections)
   ==================================================================== #}
<audio id="bgMusic"        src="{{ asset('assets/sound/Kyllian/Home_Music.mp3') }}"    loop></audio>
<audio id="clickSound"     src="{{ asset('assets/sound/Kyllian/Demarrage.mp3') }}"></audio>
<audio id="btnClickSound"  src="{{ asset('assets/sound/Kyllian/Game_Entry.mp3') }}"    preload="auto"></audio>
<audio id="badgeSound"     src="{{ asset('assets/sound/Kyllian/Achievement.mp3') }}"   preload="auto"></audio>
<audio id="RulMusic"        src="{{ asset('assets/sound/Kyllian/Rules_Music.mp3') }}"    loop></audio>
<audio id="clickRules"     src="{{ asset('assets/sound/Kyllian/Open_Rules.mp3') }}"></audio>
<audio id="closeRules"     src="{{ asset('assets/sound/Kyllian/Off_Rules.mp3') }}"></audio>
<audio id="evilSound"      src="{{ asset('assets/sound/Kyllian/K.Booo.mp3') }}"></audio>
<audio id="badgeMusic"     src="{{ asset('assets/sound/Kyllian/Badges.mp3') }}"         loop preload="auto"></audio>
<audio id="scoreMusic"     src="{{ asset('assets/sound/Kyllian/S_Scores.mp3') }}"      preload="auto"></audio>
<audio id="EndMusic"        src="{{ asset('assets/sound/Kyllian/Credits_Music.mp3') }}" loop></audio>

{# ============================================================
   SEGMENT B : AUDIO JEU (niveaux, tirs, items)
   ============================================================ #}
<audio id="lvlMusicOne"      src="{{ asset('assets/sound/Kyllian/Level_1.mp3') }}"      loop></audio>
<audio id="lvlMusicTwo"      src="{{ asset('assets/sound/Kyllian/OOZone.mp3') }}"       loop></audio>
<audio id="lvlMusicThree"    src="{{ asset('assets/sound/Kyllian/Level_2.mp3') }}"      loop></audio>
<audio id="endLevelSound"    src="{{ asset('assets/sound/Kyllian/Lvl_End.mp3') }}"      preload="auto"></audio>
<audio id="countDownSound"   src="{{ asset('assets/sound/Kyllian/Countdown.mp3') }}"    preload="auto"></audio>
<audio id="resumeSound"      src="{{ asset('assets/sound/Kyllian/Resume.mp3') }}"></audio>
<audio id="timerBeepSound"   src="{{ asset('assets/sound/Kyllian/Countdown-End.mp3') }}" preload="auto"></audio>
<audio id="popSound"         src="{{ asset('assets/sound/Kyllian/Shooting.mp3') }}"      preload="auto"></audio>
<audio id="popSoundTwo"      src="{{ asset('assets/sound/Kyllian/Shooting_2.mp3') }}"    preload="auto"></audio>
<audio id="lakituSaveSound"  src="{{ asset('assets/sound/Kyllian/Lakitu.mp3') }}"        preload="auto"></audio>
<audio id="lakituHitSound"   src="{{ asset('assets/sound/Kyllian/laki_bump.mp3') }}"     preload="auto"></audio>
<audio id="boshiSound"       src="{{ asset('assets/sound/Kyllian/hoo.mp3') }}"></audio>
<audio id="lakituEvilSound"  src="{{ asset('assets/sound/Kyllian/Boo.mp3') }}"           preload="auto"></audio>
<audio id="evilPopSound"     src="{{ asset('assets/sound/Kyllian/Yami.mp3') }}"></audio>
<audio id="ufoSound"         src="{{ asset('assets/sound/Kyllian/OVNI.mp3') }}"></audio>
<audio id="dogBarkSound"     src="{{ asset('assets/sound/Kyllian/Tokyo.mp3') }}"        preload="auto"></audio>
<audio id="bombSound"        src="{{ asset('assets/sound/Kyllian/Bomb.mp3') }}"         preload="auto"></audio>
<audio id="kyuremSound"      src="{{ asset('assets/sound/Kyllian/Kyurem.mp3') }}"        preload="auto"></audio>
<audio id="rocketSpawnSound" src="{{ asset('assets/sound/Kyllian/Arrival.mp3') }}"       preload="auto"></audio>
<audio id="rocketHitSound"   src="{{ asset('assets/sound/Kyllian/Explosion.mp3') }}"     preload="auto"></audio>
<audio id="starSound"        src="{{ asset('assets/sound/Kyllian/weeeee.mp3') }}"></audio>
<audio id="guhaSound"        src="{{ asset('assets/sound/Kyllian/guha.mp3') }}"></audio>

{# ============================================================
   SEGMENT C : CONTENEUR DE NOTIFICATIONS DE BADGES (global, visible sur toutes les sections)
   ============================================================ #}
<div id="badgeNotificationContainer"></div>

{# ============================================================
   SEGMENT D : OVERLAY PARAMÈTRES (global, partagé par toutes les sections)
   ============================================================ #}
<div id="settingsOverlay" class="modal-overlay">
    <div class="modal-content settings-box">
        <h2 class="pause-title" style="color:#000; margin-bottom:20px;">RÉGLAGES</h2>

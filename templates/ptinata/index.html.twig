        </div>

        <div class="credits-box">
            <img src="{{ asset('assets/images/Kyllian/Lakitu.png') }}" class="credits-img" id="mainCreditsImg" alt="Lakitu">
            <div class="credits-text" id="dynamicCreditsText"></div>

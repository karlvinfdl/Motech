{# ===========================================================================================================================
   PAGE 6 : FIN / REMERCIEMENTS (#page-fin)
   Correspond à pages/remerciments.html d'origine
   =========================================================================================================================== #}
<div id="page-fin" class="app-page ending-game" style="display:none;">


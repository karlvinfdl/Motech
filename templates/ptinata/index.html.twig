    const homeOverlay = document.getElementById('homeOverlay');
    const enterBtn    = document.getElementById('enterBtn');

    // Remet l'overlay en état initial si on revient (recommencer)
    if (homeOverlay) {
        homeOverlay.classList.remove('opened');
        homeOverlay.style.display = '';
    }

    // Applique le volume sauvegardé à la musique de fond
    const bgMusic = document.getElementById('bgMusic');
    if (bgMusic) bgMusic.volume = parseFloat(localStorage.getItem('musicVol') || 0.5);

    // Bouton START (clic = badge Traditionnel)
    if (enterBtn) {
        enterBtn.onclick = () => startExperience(true);
    }

    // Boutons de navigation du menu
    const btnJouer  = document.getElementById('btnNavJouer');
    const btnScores = document.getElementById('btnNavScores');
    const btnBadges = document.getElementById('btnNavBadges');

    if (btnJouer) {
        btnJouer.onclick = function() {
            navigateFromAccueil(this, 'page-regles');
        };
    }
    if (btnScores) {
        btnScores.onclick = function() {
            navigateFromAccueil(this, 'page-scores');
        };
    }
    if (btnBadges) {
        btnBadges.onclick = function() {
            navigateFromAccueil(this, 'page-badges');
        };
    }

    // Écoute clavier (Espace / Entrée)
    // On utilise un listener nommé pour pouvoir le retirer si nécessaire
    document.addEventListener('keydown', handleAccueilKeydown);
}

function handleAccueilKeydown(e) {
    const currentPage = document.querySelector('.app-page.active-page');
    if (!currentPage || currentPage.id !== 'page-accueil') {
        document.removeEventListener('keydown', handleAccueilKeydown);
        return;
    }
    if (e.code === 'Space' || e.code === 'Enter') {
        startExperience(false);
    }
}

/**
 * Démarre l'expérience (animation des portes + musique)
 * @param {boolean} isClick - true si clic bouton, false si clavier
 */
function startExperience(isClick = false) {
    if (accueilStarted) return;

    if (isClick === true) unlockBadge('click_start');

    accueilStarted = true;

    const homeOverlay = document.getElementById('homeOverlay');
    const bgMusic     = document.getElementById('bgMusic');
    const clickSound  = document.getElementById('clickSound');

    homeOverlay.classList.add('opened');

    if (clickSound) {
        clickSound.volume = parseFloat(localStorage.getItem('sfxVol') || 0.7);
        clickSound.play();
    }

    setTimeout(() => { homeOverlay.style.display = 'none'; }, 1200);

    if (bgMusic) {
        bgMusic.volume = 0;
        bgMusic.play().then(() => {
            const targetVol = parseFloat(musicSlider.value);
            const fade = setInterval(() => {
                if (bgMusic.volume < targetVol) {
                    bgMusic.volume = Math.min(targetVol, bgMusic.volume + 0.05);
                } else {
                    clearInterval(fade);
                }
            }, 100);
        }).catch(e => console.log("Audio en attente d'interaction"));
    }
}

/**
 * Navigation depuis l'accueil avec animation LOAD... et fade musique
 */
function navigateFromAccueil(btn, targetPage) {
    if (!btn || btn.dataset.leaving) return;
    btn.dataset.leaving = '1';
    btn.innerText = 'LOAD...';
    btn.style.opacity = '0.8';
    btn.style.pointerEvents = 'none';

    const btnClickSound = document.getElementById('btnClickSound');
    if (btnClickSound) {
        btnClickSound.volume = parseFloat(localStorage.getItem('sfxVol') || 0.7);
        btnClickSound.currentTime = 0;
        btnClickSound.play();
    }

    const bgMusic = document.getElementById('bgMusic');
    if (bgMusic) {
        const fadeOut = setInterval(() => {
            if (bgMusic.volume > 0.1) {
                bgMusic.volume -= 0.1;
            } else {
                bgMusic.pause();
                clearInterval(fadeOut);
            }
        }, 40);
    }

    setTimeout(() => {
        // Remet le bouton en état normal (pour le retour)
        btn.innerText = btn.id === 'btnNavJouer' ? 'JOUER' : btn.id === 'btnNavScores' ? 'SCORES' : 'BADGES';
        btn.style.opacity = '';
        btn.style.pointerEvents = '';
        delete btn.dataset.leaving;
        document.removeEventListener('keydown', handleAccueilKeydown);
        showPage(targetPage);
    }, 1900);
}
</script>


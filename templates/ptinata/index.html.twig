{# ===========================================================================================================================
   PAGE 4 : JEU (#page-jeu)
   Correspond à pages/jeu.html d'origine
   =========================================================================================================================== #}

{# ---- CORRECTION BUG 2 ----
   welcomeOverlay placé ICI, HORS de #page-jeu, pour ne pas être masqué
   par le display:none du parent. Caché par défaut, affiché par showPage('page-jeu').
   -------------------------------------------------------------------- #}
<div id="welcomeOverlay" class="welcome-overlay" style="display:none;">
    <div class="welcome-content">
        <img src="{{ asset('assets/images/Kyllian/Logo_Pinata.png') }}" alt="Licorne Shooter" class="welcome-logo">
        <div class="input-container">
            <input type="text" id="playerNameInput" placeholder="TON PSEUDO" maxlength="12">
            <button id="startGameBtn">JOUER</button>
        </div>
    </div>
</div>

<div id="page-jeu" class="app-page" style="display:none;">

    {# Conteneur de niveau (cibles) #}
    <div id="levelContainer"></div>

    {# Message de décompte (avant lancement) #}
    <div id="startMessage" class="start-message">Prêt(e) ?</div>

    {# HUD : Score & Timer #}
    <header class="game-infos">
        <div class="score">
            <img src="{{ asset('assets/images/Kyllian/licorne_1.png') }}">
            <p id="scoreValue">0</p>
        </div>
        <div class="timer" id="timerValue">1:00</div>
    </header>


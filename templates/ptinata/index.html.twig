   SEGMENT K : JAVASCRIPT — PARTIE 5 : LOGIQUE PAGE SCORES
   =========================================================================================================================== #}
<script>
// ============================================================
// BLOC JS 8 : PAGE SCORES (initScores)
// ============================================================

function initScores() {
    stopAllMusic();

    const scoreMusic   = document.getElementById('scoreMusic');
    const scoreList    = document.getElementById('scoreList');
    const btnContinue  = document.getElementById('btnContinue');

    // Musique
    if (scoreMusic) {
        const savedVol = parseFloat(localStorage.getItem('musicVol') || 0.5);
        scoreMusic.volume = savedVol;
        scoreMusic.play().catch(e => console.log('Score music bloquée'));
    }

    // Données leaderboard
    let leaderboard   = JSON.parse(localStorage.getItem('unicornLeaderboard')) || [];
    const lastScore   = localStorage.getItem('lastFinalScore');
    const lastName    = localStorage.getItem('lastPlayerName');

    // Mise à jour leaderboard si nouvelle entrée
    if (lastName && lastScore) {
        const alreadyExists = leaderboard.some(entry =>
            entry.name === lastName && entry.score === parseInt(lastScore)
        );
        if (!alreadyExists) {
            leaderboard.push({ name: lastName, score: parseInt(lastScore) });
            leaderboard.sort((a, b) => b.score - a.score);
            leaderboard = leaderboard.slice(0, 15);
            localStorage.setItem('unicornLeaderboard', JSON.stringify(leaderboard));
        }
    }

    // Affichage du classement
    if (scoreList) {
        scoreList.innerHTML = '';
        leaderboard.forEach((entry, index) => {
            const isSameName  = entry.name.trim().toUpperCase() === (lastName || '').trim().toUpperCase();
            const isSameScore = Number(entry.score) === Number(lastScore);
            const isCurrentPlayer = isSameName && isSameScore;

            const itemClass = isCurrentPlayer ? 'score-item current-player' : 'score-item';
            scoreList.innerHTML += `
                <div class="${itemClass}">
                    <div class="rank">${index + 1}</div>
                    <div class="score-bar">
                        <span class="name">${entry.name} ${isCurrentPlayer ? '(MOI)' : ''}</span>
                        <span class="value">: ${entry.score}</span>
                    </div>
                </div>`;
        });
    }

    // Notification badge en attente (rank badges)
    const pendingBadgeId = localStorage.getItem('pendingBadge');
    if (pendingBadgeId) {
        const badgesInfo = {
            'rank_1': { name: "Médaille d'Or",     img: ASSETS.images.trophy1 },
            'rank_2': { name: "Médaille d'Argent", img: ASSETS.images.trophy2 },
            'rank_3': { name: "Médaille de Bronze",img: ASSETS.images.trophy3 }
        };
        const badge = badgesInfo[pendingBadgeId];
        if (badge) {
            const container  = document.getElementById('badgeNotificationContainer');
            const sound      = document.getElementById('badgeSound');
            if (container) {
                const notif = document.createElement('div');
                notif.className = 'badge-notification';
                notif.innerHTML = `
                    <div class="badge-icon-notify"><img src="${badge.img}" alt="Icon"></div>
                    <div class="badge-info-notify">
                        <p class="title-notif">Badge Débloqué !</p>
                        <p class="name-notif">${badge.name}</p>
                    </div>`;
                container.appendChild(notif);
                if (sound) {
                    sound.volume = parseFloat(localStorage.getItem('sfxVol') || 0.7);
                    sound.play().catch(e => {});
                }
                setTimeout(() => notif.classList.add('show'), 500);
                setTimeout(() => {
                    notif.classList.remove('show');
                    setTimeout(() => notif.remove(), 600);
                }, 5000);
            }
        }
        localStorage.removeItem('pendingBadge');
    }

    // Bouton continuer → page fin
    const goToFin = () => {
        if (scoreMusic) {
            const fadeOut = setInterval(() => {
                if (scoreMusic.volume > 0.1) {
                    scoreMusic.volume -= 0.1;
                } else {
                    scoreMusic.pause();
                    clearInterval(fadeOut);
                    document.removeEventListener('keydown', handleScoresKeydown);
                    showPage('page-fin');
                }
            }, 40);
        } else {
            document.removeEventListener('keydown', handleScoresKeydown);
            showPage('page-fin');
        }
    };

    if (btnContinue) btnContinue.onclick = goToFin;

    function handleScoresKeydown(e) {
        const currentPage = document.querySelector('.app-page.active-page');
        if (!currentPage || currentPage.id !== 'page-scores') {
            document.removeEventListener('keydown', handleScoresKeydown);
            return;
        }
        if (e.code === 'Enter' || e.code === 'Space') {
            e.preventDefault();
            goToFin();
        }
    }

    document.addEventListener('keydown', handleScoresKeydown);
}
</script>

{# ===========================================================================================================================
   SEGMENT L : JAVASCRIPT — PARTIE 6 : LOGIQUE PAGE FIN
   =========================================================================================================================== #}
<script>
// ============================================================
// BLOC JS 9 : PAGE FIN / REMERCIEMENTS (initFin)
// Inclut confetti CDN (chargé conditionnellement)
// ============================================================

// Chargement du script confetti (une seule fois)
if (!window.confettiLoaded) {
    const confettiScript = document.createElement('script');
    confettiScript.src = 'https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js';
    confettiScript.onload = () => { window.confettiLoaded = true; };
    document.head.appendChild(confettiScript);
}

function initFin() {
    stopAllMusic();

    const endMusic           = document.getElementById('EndMusic');
    const finalRankEl        = document.getElementById('finalRank');
    const scoreBanner        = document.querySelector('#page-fin .score-final');
    const finalScoreDisplay  = document.getElementById('finalScoreDisplay');
    const creditsBox         = document.querySelector('#page-fin .credits-box');
    const creditsText        = document.getElementById('dynamicCreditsText');
    const mainImg            = document.getElementById('mainCreditsImg');
    const evilImg            = document.getElementById('evilCreditsImg');
    const btnRetry           = document.getElementById('btnRetry');
    const btnHome            = document.getElementById('btnHome');

    const lastScore   = parseInt(localStorage.getItem('lastFinalScore')) || 0;
    const playerName  = localStorage.getItem('lastPlayerName') || 'Joueur';
    const leaderboard = JSON.parse(localStorage.getItem('unicornLeaderboard')) || [];

    const rank = leaderboard.findIndex(e =>
        e.name === playerName && Number(e.score) === lastScore
    ) + 1;

    // Musique de fin
    const playEndMusic = () => {
        if (endMusic && endMusic.paused) {
            const savedVol = parseFloat(localStorage.getItem('musicVol') || 0.5);
            endMusic.volume = savedVol;
            endMusic.play()
                .then(() => document.removeEventListener('click', playEndMusic))
                .catch(e => console.log('End music bloquée'));
        }
    };
    playEndMusic();
    document.addEventListener('click', playEndMusic);

    // Affichage score et rang
    if (finalScoreDisplay) finalScoreDisplay.textContent = `${playerName} : ${lastScore}`;
    if (finalRankEl)        finalRankEl.textContent = rank > 0 ? rank : '-';

    // Remise à zéro des images (si on recommence)
    if (mainImg) mainImg.src = ASSETS.images.logoPinata.replace('Logo_Pinata', 'Lakitu');
    if (evilImg) { evilImg.src = ''; evilImg.style.display = 'none'; }

    // Logique podium (Top 3)
    let confettiColors = ['#f5c2cf', '#000000'];

    if (rank >= 1 && rank <= 3) {
        let color = '', mainSrc = '', evilSrc = '';

        if (rank === 1) {
            color = '#FFD700';
            confettiColors = ['#FFD700', '#FFF9E3', '#000000'];
            mainSrc = ASSETS.images.rank1Cloud;
            evilSrc = ASSETS.images.rank1EvilCloud;
        } else if (rank === 2) {
            color = '#C0C0C0';
            confettiColors = ['#C0C0C0', '#FFFFFF', '#000000'];
            mainSrc = ASSETS.images.rank2Cloud;
            evilSrc = ASSETS.images.rank2EvilCloud;
        } else if (rank === 3) {
            color = '#CD7F32';
            confettiColors = ['#CD7F32', '#F5E6D7', '#000000'];
            mainSrc = ASSETS.images.rank3Cloud;
            evilSrc = ASSETS.images.rank3EvilCloud;
        }

        if (mainImg) mainImg.src = mainSrc;
        if (evilImg) {
            evilImg.src = evilSrc;
            evilImg.style.display = 'block';
            evilImg.style.marginRight = '20px';
            evilImg.style.marginLeft = '0';
        }

        if (scoreBanner) {
            scoreBanner.style.backgroundColor = 'black';
            scoreBanner.style.border = `3px solid ${color}`;
            scoreBanner.style.color = 'white';
        }
        if (finalRankEl) {
            finalRankEl.style.backgroundColor = color;
            finalRankEl.style.color = 'black';
            finalRankEl.style.fontWeight = 'bold';
        }
        if (creditsBox) {
            creditsBox.style.backgroundColor = 'black';
            creditsBox.style.border = `4px solid ${color}`;
            creditsBox.style.color = 'white';
            creditsBox.style.justifyContent = 'space-between';
        }
        [btnRetry, btnHome].forEach(btn => {
            if (btn) {
                btn.style.backgroundColor = color;
                btn.style.color = 'black';
                btn.style.fontWeight = 'bold';
            }
        });
    } else {
        // Reset styles pour les rangs hors podium
        if (scoreBanner) { scoreBanner.style.backgroundColor = ''; scoreBanner.style.border = ''; scoreBanner.style.color = ''; }
        if (finalRankEl) { finalRankEl.style.backgroundColor = '#f5c2cf'; finalRankEl.style.color = ''; finalRankEl.style.fontWeight = ''; }
        if (creditsBox)  { creditsBox.style.backgroundColor = ''; creditsBox.style.border = ''; creditsBox.style.color = ''; creditsBox.style.justifyContent = ''; }
        [btnRetry, btnHome].forEach(btn => { if (btn) { btn.style.backgroundColor = ''; btn.style.color = ''; btn.style.fontWeight = ''; } });
    }

    if (creditsText) {
        creditsText.innerHTML = `
            <p><strong>Bravo ${playerName} !</strong></p>
            <p>Tu termines à la ${rank}${rank === 1 ? 'er' : 'e'} place avec ${lastScore} points.</p>
        `;
    }

    // Confettis
    const fireConfetti = () => {
        if (typeof confetti !== 'function') return;
        const fire = (particleCount, angle, x) => {
            confetti({ particleCount, angle, spread: 55, origin: { x, y: 0.6 }, colors: confettiColors });
        };
        fire(100, 60, 0.1);
        fire(100, 120, 0.9);
        if (rank === 1) {
            setTimeout(() => { fire(150, 60, 0.1); fire(150, 120, 0.9); }, 400);
        }
    };

    // Lance les confettis dès que le script est chargé
    if (window.confettiLoaded) {
        fireConfetti();
    } else {
        setTimeout(fireConfetti, 1000);
    }

    // Fade out musique + navigation
    const fadeAndGo = (targetPage) => {
        document.removeEventListener('click', playEndMusic);
        if (endMusic) {
            const fade = setInterval(() => {
                if (endMusic.volume > 0.1) {
                    endMusic.volume -= 0.1;
                } else {
                    clearInterval(fade);
                    endMusic.pause();
                    showPage(targetPage);
                }
            }, 50);
        } else {
            showPage(targetPage);
        }
    };

    if (btnRetry) btnRetry.onclick = () => fadeAndGo('page-jeu');
    if (btnHome)  btnHome.onclick  = () => fadeAndGo('page-accueil');
}
</script>

{# ===========================================================================================================================
   SEGMENT M : JAVASCRIPT — PARTIE 7 : MOTEUR DE JEU COMPLET (UnicornShooter + Target)
   =========================================================================================================================== #}
<script>
// ============================================================
// BLOC JS 10 : MOTEUR DE JEU — initJeu() + Classes UnicornShooter & Target
// Transposition intégrale depuis jeu.html (aucune ligne supprimée)
// ============================================================

// Référence globale au jeu (pour pouvoir le détruire/recréer)
let gameInstance = null;

function initJeu() {
    stopAllMusic();

    // Reset complet de la zone de jeu entre les parties
    const levelContainer = document.getElementById('levelContainer');
    if (levelContainer) levelContainer.innerHTML = '';

    // ---- CORRECTION BUG 3 ----
    // welcomeOverlay est maintenant HORS de #page-jeu, géré par showPage().
    // On remet seulement les overlays internes à la page jeu.
    const endOverlay     = document.getElementById('endOverlay');
    const pauseOverlay   = document.getElementById('pauseOverlay');
    const startMsgEl     = document.getElementById('startMessage');
    const restartEl      = document.getElementById('restartCountdown');

    if (endOverlay)   endOverlay.style.display   = 'none';
    if (pauseOverlay) pauseOverlay.style.display = 'none';
    if (startMsgEl)   startMsgEl.style.display   = 'none';
    if (restartEl)    restartEl.style.display     = 'none';

    // Reset HUD
    const scoreVal = document.getElementById('scoreValue');
    const timerVal = document.getElementById('timerValue');
    if (scoreVal) scoreVal.textContent = '0';
    if (timerVal) timerVal.textContent = '1:00';

    // Reset nom d'input
    const nameInput = document.getElementById('playerNameInput');
    if (nameInput) nameInput.value = '';

    // Remise du body en world_1
    document.body.classList.remove('world_2', 'world_3');
    document.body.classList.add('world_1');

    // Reset du message de niveau
    const currentLevelEl = document.querySelector('.current-level');
    if (currentLevelEl) currentLevelEl.textContent = 'Level 1';

    // ---- CORRECTION BUG 4 ----
    // Détruit l'ancienne instance proprement avant d'en créer une nouvelle
    if (gameInstance) {
        gameInstance.isPlaying = false;
        clearInterval(gameInstance.timerInterval);
        clearTimeout(gameInstance.spawnTimeout);
        if (gameInstance._keyboardHandler) {
            document.removeEventListener('keydown', gameInstance._keyboardHandler);
        }
        gameInstance = null;
    }

    // Lancement du moteur
    gameInstance = new UnicornShooter();
}

// ============================================================
// CLASSE UnicornShooter
// ============================================================
class UnicornShooter {
    constructor() {
        // --- Variables d'état ---
        this.score = 0;
        this.totalScore = 0;
        this.timeLeft = 60;
        this.startTime = null;
        this.isPlaying = false;
        this.isPaused = false;
        this.currentLevel = 1;
        this.difficultyMultiplier = 0.70;
        this.spawnRate = 700;
        this.pseudo = 'JOUEUR';
        this.targets = [];
        this.timerInterval = null;
        this.spawnTimeout = null;
        this.comboCount = 0;
        this.lastHitTime = 0;
        this.comboFreezeUntil = 0;
        this.totalClicks = 0;
        this.isInvulnerable = false;
        this.godModeTimeout = null;
        this.isInverseMode = false;
        this.inverseModeTimeout = null;
        this.isSuperComboActive = false;
        this.superComboTimer = null;
        this.boshiUnlocked = false;
        this.isLowTimeActive = false;

        // --- Éléments HTML ---
        this.gameArea        = document.getElementById('levelContainer');
        this.scoreElement    = document.getElementById('scoreValue');
        this.timerElement    = document.getElementById('timerValue');
        this.startMsg        = document.getElementById('startMessage');
        this.welcomeOverlay  = document.getElementById('welcomeOverlay');
        this.endOverlay      = document.getElementById('endOverlay');
        this.nameInput       = document.getElementById('playerNameInput');
        this.startBtn        = document.getElementById('startGameBtn');
        this.pauseOverlay    = document.getElementById('pauseOverlay');
        this.resumeBtn       = document.getElementById('resumeBtn');
        this.settingsBtnGame = document.getElementById('settingsBtn');
        this.quitBtn         = document.getElementById('quitBtn');
        this.settingsOverlayEl = document.getElementById('settingsOverlay');
        this.musicSliderEl   = document.getElementById('musicVolume');
        this.sfxSliderEl     = document.getElementById('sfxVolume');
        this.closeSettingsBtnEl = document.getElementById('closeSettingsBtn');

        // --- Sons ---
        this.popSounds      = [document.getElementById('popSound'), document.getElementById('popSoundTwo')];
        this.countDownSound = document.getElementById('countDownSound');
        this.resumeSound    = document.getElementById('resumeSound');
        this.endLevelSound  = document.getElementById('endLevelSound');
        this.bombSound      = document.getElementById('bombSound');
        this.dogSound       = document.getElementById('dogBarkSound');
        this.ufoSound       = document.getElementById('ufoSound');
        this.evilSound      = document.getElementById('evilPopSound');
        this.lakituSaveSound  = document.getElementById('lakituSaveSound');
        this.lakituEvilSound  = document.getElementById('lakituEvilSound');
        this.lakituHitSound   = document.getElementById('lakituHitSound');
        this.starSound        = document.getElementById('starSound');
        this.guhaSound        = document.getElementById('guhaSound');
        this.boshiSound       = document.getElementById('boshiSound');
        this.timerBeepSound   = document.getElementById('timerBeepSound');
        this.kyuremSound      = document.getElementById('kyuremSound');
        this.rocketSpawnSound = document.getElementById('rocketSpawnSound');
        this.rocketHitSound   = document.getElementById('rocketHitSound');

        // --- Images des cibles normales ---
        // ---- CORRECTION BUG 1 ---- ASSETS.images.Kyllian.xxx n'existe pas → ASSETS.images.xxx
        this.targetImages = [
            ASSETS.images.licorne1,
            ASSETS.images.licorne2,
            ASSETS.images.licorne4,
            ASSETS.images.licorne5
        ];

        this.updateMusicElement();
        this.applyVolumes();
        this.setupWelcome();
        this.setupPause();
        this.setupKeyboard();
        this.setupSettingsGame();
    }

    // -------------------------------------------------------
    showTemporaryTimer(durationMs, color) {
        const oldTimer = document.getElementById('temp-game-timer');
        if (oldTimer) oldTimer.remove();

        const timerEl = document.createElement('div');
        timerEl.id = 'temp-game-timer';
        timerEl.style.cssText = `
            position:fixed; top:20px; left:50%; transform:translateX(-50%);
            font-size:40px; font-weight:bold; color:${color};
            text-shadow:0 0 15px ${color}; z-index:10002; pointer-events:none;`;
        document.body.appendChild(timerEl);

        let timeLeft = durationMs / 1000;
        timerEl.innerText = timeLeft + 's';
        const interval = setInterval(() => {
            timeLeft--;
            timerEl.innerText = timeLeft + 's';
            if (timeLeft <= 0) { clearInterval(interval); timerEl.remove(); }
        }, 1000);
    }

    // -------------------------------------------------------
    activateSuperCombo() {
        this.isSuperComboActive = true;
        unlockBadge('super_combo');
        if (this.superComboTimer) clearTimeout(this.superComboTimer);
        if (this.scoreElement) this.scoreElement.style.color = '#b300ff';
        this.superComboTimer = setTimeout(() => {
            this.isSuperComboActive = false;
            if (this.scoreElement) this.scoreElement.style.color = '';
        }, 5000);
    }

    // -------------------------------------------------------
    applyVolumes() {
        const mVol = parseFloat(localStorage.getItem('musicVol') || 0.5);
        const sVol = parseFloat(localStorage.getItem('sfxVol')   || 0.7);

        if (this.bgMusic) this.bgMusic.volume = mVol;

        const allSfx = [
            ...this.popSounds, this.countDownSound, this.resumeSound, this.endLevelSound,
            this.bombSound, this.dogSound, this.ufoSound, this.evilSound,
            this.lakituSaveSound, this.lakituEvilSound, this.lakituHitSound,
            this.starSound, this.timerBeepSound, this.guhaSound, this.boshiSound,
            this.rocketSpawnSound, this.rocketHitSound, this.kyuremSound
        ];
        allSfx.forEach(s => { if (s) s.volume = sVol; });
    }

    // -------------------------------------------------------
    // ---- CORRECTION BUG 5 ----
    // setupSettingsGame : ne réécrase PAS closeSettingsBtn global
    // pour ne pas casser la fermeture des paramètres sur les autres pages
    setupSettingsGame() {
        if (this.settingsBtnGame) {
            this.settingsBtnGame.onclick = () => {
                if (this.settingsOverlayEl) {
                    this.settingsOverlayEl.style.zIndex = '90000';
                    this.settingsOverlayEl.style.display = 'flex';
                }
                unlockBadge('settings_pro');
            };
        }
        if (this.closeSettingsBtnEl) {
            this.closeSettingsBtnEl.onclick = () => {
                localStorage.setItem('musicVol', this.musicSliderEl.value);
                localStorage.setItem('sfxVol',   this.sfxSliderEl.value);
                this.applyVolumes();
                if (this.settingsOverlayEl) this.settingsOverlayEl.style.display = 'none';
            };
        }
    }

    // -------------------------------------------------------
    updateMusicElement() {
        const ids = ['lvlMusicOne', 'lvlMusicTwo', 'lvlMusicThree'];
        this.bgMusic = document.getElementById(ids[this.currentLevel - 1]);
    }

    // -------------------------------------------------------
    setupWelcome() {
        if (this.startBtn) {
            this.startBtn.onclick = () => {
                const val = this.nameInput ? this.nameInput.value.trim() : '';
                if (val !== '') {
                    this.pseudo = val.toUpperCase();
                    if (this.welcomeOverlay) this.welcomeOverlay.style.display = 'none';

                    let totalGames = parseInt(localStorage.getItem('totalGamesPlayed') || 0) + 1;
                    localStorage.setItem('totalGamesPlayed', totalGames);

                    this.initLevel();
                } else {
                    alert('Entre un pseudo !');
                }
            };
        }
    }

    // -------------------------------------------------------
    setupPause() {
        const pauseBtn = document.getElementById('pauseBtn');
        if (pauseBtn) {
            pauseBtn.onclick = () => {
                if (!this.isPlaying) return;
                if (this.isPaused) this.resumeWithCountdown();
                else this.togglePauseMenu(true);
            };
        }
        if (this.resumeBtn)  this.resumeBtn.onclick  = () => this.resumeWithCountdown();
        if (this.quitBtn) {
            this.quitBtn.onclick = () => {
                if (confirm('Quitter ?')) {
                    this.isPlaying = false;
                    clearInterval(this.timerInterval);
                    clearTimeout(this.spawnTimeout);
                    this.stopTimeAlert();
                    if (this.bgMusic) { this.bgMusic.pause(); this.bgMusic.currentTime = 0; }
                    // Nettoie les cibles et overlays
                    if (this.gameArea) this.gameArea.innerHTML = '';
                    if (this.pauseOverlay) this.pauseOverlay.style.display = 'none';
                    showPage('page-accueil');
                }
            };
        }
    }

    // -------------------------------------------------------
    resumeWithCountdown() {
        if (!this.isPaused) return;
        if (this.pauseOverlay) this.pauseOverlay.style.display = 'none';

        const restartEl = document.getElementById('restartCountdown');
        if (restartEl) {
            restartEl.className = 'restart-countdown';
            restartEl.style.display = 'block';
            restartEl.textContent = 'Bien prêt(e) ??';
        }

        if (this.resumeSound) { this.resumeSound.currentTime = 0; this.resumeSound.play(); }

        setTimeout(() => { if (restartEl) restartEl.textContent = 'Go !!'; }, 1000);
        setTimeout(() => {
            if (restartEl) restartEl.style.display = 'none';
            this.togglePauseMenu(false);
        }, 1500);
    }

    // -------------------------------------------------------
    setupKeyboard() {
        this._keyboardHandler = (e) => {
            // Vérifie qu'on est bien sur la page jeu
            const currentPage = document.querySelector('.app-page.active-page');
            if (!currentPage || currentPage.id !== 'page-jeu') {
                document.removeEventListener('keydown', this._keyboardHandler);
                return;
            }

            if (this.endOverlay && this.endOverlay.style.display === 'flex') {
                if (e.code === 'Space' || e.code === 'Enter') {
                    e.preventDefault();
                    if (this.currentLevel < 3) this.nextLevel();
                    else this.finishGame();
                }
                return;
            }

            if (!this.isPlaying) return;
            if (e.code === 'Space' || e.code === 'Escape') {
                e.preventDefault();
                if (this.isPaused) this.resumeWithCountdown();
                else this.togglePauseMenu(true);
            }
        };
        document.addEventListener('keydown', this._keyboardHandler);
    }

    // -------------------------------------------------------
    togglePauseMenu(pauseActive) {
        const pauseBtn = document.getElementById('pauseBtn');
        this.isPaused = pauseActive;

        if (this.isPaused) {
            unlockBadge('pause_master');
            if (this.pauseOverlay) {
                this.pauseOverlay.style.zIndex = '2000';
                this.pauseOverlay.style.display = 'flex';
            }
            if (pauseBtn) pauseBtn.textContent = '▶';
            if (this.gameArea) {
                this.gameArea.style.pointerEvents = 'none';
                this.gameArea.style.filter = 'blur(4px)';
            }
            if (this.bgMusic) this.bgMusic.pause();
            if (this.timerBeepSound) this.timerBeepSound.pause();
            clearInterval(this.timerInterval);
            clearTimeout(this.spawnTimeout);
        } else {
            if (pauseBtn) pauseBtn.textContent = '⏸';
            if (this.gameArea) {
                this.gameArea.style.pointerEvents = 'auto';
                this.gameArea.style.filter = 'none';
            }
            if (this.bgMusic) this.bgMusic.play();
            if (this.isLowTimeActive && this.timerBeepSound) this.timerBeepSound.play();
            this.startTimer();
            this.spawnLoop();
        }
    }

    // -------------------------------------------------------
    initLevel() {
        if (this.startMsg) {
            this.startMsg.className = 'start-message';
            this.startMsg.style.display = 'block';
            this.startMsg.textContent = `Prêt ${this.pseudo} ?`;
        }
        if (this.countDownSound) { this.countDownSound.currentTime = 0; this.countDownSound.play(); }

        setTimeout(() => { if (this.startMsg) this.startMsg.textContent = 'Attention...'; }, 1000);
        setTimeout(() => {
            if (this.startMsg) this.startMsg.textContent = "C'est parti !";
            if (this.bgMusic) { this.bgMusic.currentTime = 0; this.bgMusic.play(); }
            this.startTime = Date.now();
        }, 2000);
        setTimeout(() => {
            if (this.startMsg) this.startMsg.style.display = 'none';
            this.isPlaying = true;
            this.isPaused = false;
            this.startTimer();
            this.spawnLoop();
            this.update();

            // Badge Pacifiste : aucune action dans les 10 premières secondes
            setTimeout(() => {
                if (this.isPlaying && this.score === 0) unlockBadge('peaceful');
            }, 10000);
        }, 3000);
    }

    // -------------------------------------------------------
    checkTimeAlert() {
        if (this.timeLeft <= 12 && this.timeLeft > 0) {
            if (!this.isLowTimeActive) {
                this.isLowTimeActive = true;
                if (this.timerElement) this.timerElement.classList.add('low-time-alert');
                if (this.timerBeepSound) {
                    this.timerBeepSound.currentTime = 0;
                    this.timerBeepSound.loop = true;
                    this.timerBeepSound.play().catch(e => {});
                }
            }
        } else {
            if (this.isLowTimeActive) this.stopTimeAlert();
        }
    }

    // -------------------------------------------------------
    stopTimeAlert() {
        this.isLowTimeActive = false;
        if (this.timerElement) this.timerElement.classList.remove('low-time-alert');
        if (this.timerBeepSound) { this.timerBeepSound.pause(); this.timerBeepSound.currentTime = 0; }
    }

    // -------------------------------------------------------
    startTimer() {
        if (this.timerInterval) clearInterval(this.timerInterval);
        this.timerInterval = setInterval(() => {
            if (this.isPlaying && !this.isPaused) {
                this.timeLeft--;
                this.updateUI();
                this.checkTimeAlert();

                if (this.startTime) {
                    const elapsed = (Date.now() - this.startTime) / 1000;
                    if (elapsed >= 180) unlockBadge('time_master_3m');
                }

                if (this.timeLeft <= 0) this.endGame();
            }
        }, 1000);
    }

    // -------------------------------------------------------
    updateUI() {
        const mins = Math.floor(this.timeLeft / 60);
        const secs = this.timeLeft % 60;
        if (this.timerElement) this.timerElement.textContent = `${mins}:${secs < 10 ? '0' : ''}${secs}`;
        if (this.scoreElement) this.scoreElement.textContent = this.score;
    }

    // -------------------------------------------------------
    spawnLoop() {
        if (this.isPlaying && !this.isPaused) {
            let img;
            const rand = Math.random();

            // ---- CORRECTION BUG 1 ---- ASSETS.images.Kyllian.xxx → ASSETS.images.xxx
            if (rand < 0.008) {
                img = ASSETS.images.kyuremGif;
            } else if (rand < 0.02) {
                img = ASSETS.images.chienGif;
            } else if (rand < 0.07) {
                img = ASSETS.images.litimesGif;
            } else if (rand < 0.10) {
                img = ASSETS.images.rocketGif;
            } else if (rand < 0.13) {
                img = ASSETS.images.ovniGif;
            } else if (this.currentLevel >= 2 && rand < 0.16) {
                img = ASSETS.images.lakituGif;
            } else if (this.currentLevel >= 2 && rand < 0.18) {
                img = ASSETS.images.evilLakituGif;
            } else if (rand < (0.25 + this.currentLevel * 0.03)) {
                img = Math.random() > 0.5 ? ASSETS.images.bombGif : ASSETS.images.licorne3evil;
            } else {
                if (this.boshiUnlocked && Math.random() < 0.15) {
                    img = ASSETS.images.boshiPng;
                } else {
                    img = this.targetImages[Math.floor(Math.random() * this.targetImages.length)];
                }
            }
            this.targets.push(new Target(img, this));
        }

        const levelFactor = 1 + (this.currentLevel - 1) * 0.2;
        const nextSpawn   = (this.spawnRate / levelFactor) + Math.random() * 800;
        this.spawnTimeout = setTimeout(() => this.spawnLoop(), nextSpawn);
    }

    // -------------------------------------------------------
    update() {
        if (this.isPlaying && !this.isPaused) {
            this.targets.forEach((target, index) => {
                target.move();
                if (target.y > window.innerHeight + 100 || target.y < -200 ||
                    target.x > window.innerWidth + 300  || target.x < -300) {

                    if (target.y > window.innerHeight + 100 && target.isBomb) {
                        let totalIgnored = parseInt(localStorage.getItem('totalBombsIgnored') || 0) + 1;
                        localStorage.setItem('totalBombsIgnored', totalIgnored);
                        if (totalIgnored >= 30) unlockBadge('bomb_dodger');
                    }
                    target.remove();
                    this.targets.splice(index, 1);
                }
            });
        }
        requestAnimationFrame(() => this.update());
    }

    // -------------------------------------------------------
    fadeOutAndStopMusic() {
        if (!this.bgMusic) return;
        const currentAudio = this.bgMusic;
        const fadeOut = setInterval(() => {
            if (currentAudio.volume > 0.05) currentAudio.volume -= 0.05;
            else { currentAudio.pause(); currentAudio.currentTime = 0; clearInterval(fadeOut); }
        }, 100);
    }

    // -------------------------------------------------------
    endGame() {
        this.isPlaying = false;
        clearInterval(this.timerInterval);
        clearTimeout(this.spawnTimeout);
        this.stopTimeAlert();
        document.removeEventListener('keydown', this._keyboardHandler);

        // Badges de fin de niveau / score
        if (this.currentLevel === 1) unlockBadge('world_1_clear');
        if (this.currentLevel === 2) unlockBadge('world_2_clear');
        if (this.currentLevel === 3) unlockBadge('world_3_clear');
        if (this.score >= 1500)  unlockBadge('score_1500');
        if (this.score >= 6500)  unlockBadge('score_6500');
        if (this.score >= 10000) unlockBadge('score_10000');
        if (this.score === 0)    unlockBadge('ultimate_clear');

        if (this.endLevelSound) { this.endLevelSound.currentTime = 0; this.endLevelSound.play(); }
        this.fadeOutAndStopMusic();
        this.totalScore += this.score;

        const finalScoreEl = document.getElementById('finalScore');
        if (finalScoreEl) finalScoreEl.textContent = this.score;

        if (this.endOverlay) this.endOverlay.style.display = 'flex';

        const commentEl = document.getElementById('endComment');
        if (commentEl) {
            if      (this.score === 0)         commentEl.textContent = 'Tu as dormi ???';
            else if (this.score < 1200)        commentEl.textContent = 'Pas ouf, tout ça...';
            else if (this.score < 3000)        commentEl.textContent = 'Mouais pas trop mal...';
            else if (this.score < 6500)        commentEl.textContent = "Je dirai pas que t'es meilleur mais tu progresses...";
            else if (this.score < 9999)        commentEl.textContent = "Mais c'est que tu commences à devenir bon dis moi !";
            else                               commentEl.textContent = "Nan t'es bon, t'es bon GG !!";
        }

        const continueBtn = document.querySelector('.click-to-continue');
        if (continueBtn) {
            continueBtn.onclick = (e) => {
                e.stopPropagation();
                if (this.currentLevel < 3) this.nextLevel();
                else this.finishGame();
            };
        }

        // Ré-enregistre le keyboard handler pour la fin de niveau
        document.addEventListener('keydown', this._keyboardHandler);
    }

    // -------------------------------------------------------
    nextLevel() {
        this.currentLevel++;
        document.removeEventListener('keydown', this._keyboardHandler);

        this.updateMusicElement();
        this.applyVolumes();
        this.boshiUnlocked = false;

        // Met à jour les classes body pour le fond du niveau
        document.body.classList.remove('world_1', 'world_2', 'world_3');
        document.body.classList.add(`world_${this.currentLevel}`);

        const currentLevelEl = document.querySelector('.current-level');
        if (currentLevelEl) currentLevelEl.textContent = `Level ${this.currentLevel}`;

        if (this.endOverlay) this.endOverlay.style.display = 'none';

        this.score = 0;
        this.timeLeft = 60;
        this.updateUI();
        if (this.gameArea) this.gameArea.innerHTML = '';
        this.targets = [];

        this.setupKeyboard();
        this.initLevel();
    }

    // -------------------------------------------------------
    finishGame() {
        document.removeEventListener('keydown', this._keyboardHandler);

        let leaderboard = JSON.parse(localStorage.getItem('unicornLeaderboard')) || [];
        const newEntry  = { name: this.pseudo, score: this.totalScore };
        leaderboard.push(newEntry);
        leaderboard.sort((a, b) => b.score - a.score);

        const playerRank = leaderboard.findIndex(e =>
            e.name === this.pseudo && e.score === this.totalScore
        ) + 1;

        if (playerRank === 1) unlockBadge('rank_1');
        if (playerRank === 2) unlockBadge('rank_2');
        if (playerRank === 3) unlockBadge('rank_3');

        leaderboard = leaderboard.slice(0, 15);
        localStorage.setItem('unicornLeaderboard', JSON.stringify(leaderboard));
        localStorage.setItem('lastFinalScore',  this.totalScore);
        localStorage.setItem('lastPlayerName',  this.pseudo);

        // Nettoie la page jeu
        if (this.gameArea) this.gameArea.innerHTML = '';

        showPage('page-scores');
    }
}

// ============================================================
// CLASSE Target (Cibles du jeu)
// ============================================================
class Target {
    constructor(imgSrc, game, isDropped = false) {
        this.game    = game;
        this.element = document.createElement('img');
        this.element.src       = imgSrc;
        this.element.className = 'targets';

        // Détection du type de cible via le chemin d'image
        this.isBomb        = imgSrc.includes('Bomb.gif');
        this.isDog         = imgSrc.includes('Chien.gif');
        this.isKyurem      = imgSrc.includes('Kyurem.gif');
        this.isUFO         = imgSrc.includes('OVNI.gif');
        this.isRocket      = imgSrc.includes('Rocket.gif');
        this.isEvilLicorne = imgSrc.includes('Licornes-3.png');
        this.isLakitu      = imgSrc.includes('Lakitu.gif')      && !imgSrc.includes('Evil');
        this.isEvilLakitu  = imgSrc.includes('Evil_Lakitu.gif');
        this.isStarUnicorn = imgSrc.includes('Litimes.gif');
        this.isBoshi       = imgSrc.includes('Boshi.png');

        // Classes CSS spécifiques
        if (this.isBomb)        this.element.classList.add('bomb-target');
        if (this.isDog)         this.element.classList.add('dog-target');
        if (this.isKyurem)      this.element.classList.add('kyurem-target');
        if (this.isUFO)         this.element.classList.add('ufo-target');
        if (this.isRocket)      this.element.classList.add('rocket-target');
        if (this.isEvilLicorne) this.element.classList.add('evil-target');
        if (this.isLakitu)      this.element.classList.add('lakitu-target');
        if (this.isEvilLakitu)  this.element.classList.add('evil-lakitu-target');
        if (this.isStarUnicorn) this.element.classList.add('star-target');
        if (this.isBoshi)       this.element.classList.add('boshi-target');

        if (this.isLakitu || this.isEvilLakitu) {
            this.element.style.width  = '90px';
            this.element.style.height = 'auto';
        }
        if (this.isBoshi) {
            this.element.style.height = 'auto';
        }

        this.dropTimer = 0;
        this.hp = (this.isLakitu && !this.isEvilLakitu) ? 3 : 1;

        // Gestionnaire de clic
        this.element.onmousedown = (e) => {
            e.preventDefault();
            if (!this.game.isPaused && this.game.isPlaying) {
                this.game.isPeaceful = false;

                if (this.element.classList.contains('ghost-mode')) {
                    this.explode();
                    return;
                }

                this.hp--;

                if (this.isLakitu && !this.isEvilLakitu && this.hp > 0) {
                    this.showFloatingText(`${3 - this.hp}/3`, e.clientX, e.clientY, false, '#00FF00');
                }

                if (this.hp <= 0) {
                    this.explode();
                } else {
                    if (this.isLakitu && !this.isEvilLakitu) {
                        if (this.game.lakituHitSound) { this.game.lakituHitSound.currentTime = 0; this.game.lakituHitSound.play(); }
                        this.element.style.filter = 'brightness(2) contrast(2)';
                        this.element.classList.add('hit-shake');
                        setTimeout(() => { this.element.style.filter = ''; this.element.classList.remove('hit-shake'); }, 150);
                    }
                }
            }
        };

        // --- Physique / Trajectoire ---
        const mult         = this.game.difficultyMultiplier;
        const levelSlowdown = 1 + (this.game.currentLevel - 1) * 0.15;

        if (this.isStarUnicorn) {
            if (this.game.starSound) { this.game.starSound.currentTime = 0; this.game.starSound.play(); }
            this.side = Math.random() > 0.5 ? 'left' : 'right';
            this.x    = this.side === 'left' ? -150 : window.innerWidth + 150;
            this.y    = Math.random() * (window.innerHeight * 0.4);
            const speed = 10.0;
            this.vx    = this.side === 'left' ? (speed * mult) : -(speed * mult);
            this.vy    = 0;
            this.gravity      = 0;
            this.rotationSpeed = 10;
        }
        else if (isDropped) {
            this.gravity      = 0.015 * mult;
            this.vx           = (Math.random() - 0.5) * 0.8 * mult;
            this.vy           = 0.25 * mult;
            this.x            = 0;
            this.y            = 0;
            this.rotationSpeed = (Math.random() - 0.5) * 1;
        }
        else if (this.isUFO || this.isLakitu || this.isEvilLakitu || this.isRocket) {
            if (this.isRocket && this.game.rocketSpawnSound) {
                this.game.rocketSpawnSound.currentTime = 0;
                this.game.rocketSpawnSound.play();
            }
            this.side = Math.random() > 0.5 ? 'left' : 'right';
            this.x    = this.side === 'left' ? -150 : window.innerWidth + 150;
            this.y    = Math.random() * (window.innerHeight * 0.3);

            const horizontalSpeed = this.isRocket ? 7 : 2.5;
            this.vx    = this.side === 'left' ? (horizontalSpeed * mult) : -(horizontalSpeed * mult);
            this.vy    = 0;
            this.gravity      = 0;
            this.rotationSpeed = 0;

            if (this.isRocket) {
                this.element.className = this.side === 'left' ? 'targets rocket-right' : 'targets rocket-left';
            }
        }
        else {
            this.x    = Math.random() * (window.innerWidth - 270);
            this.y    = window.innerHeight;
            this.gravity      = 0.012 * mult * levelSlowdown;
            this.vy           = -(4.0 + Math.random() * 1.5) * mult;
            this.vx           = (Math.random() - 0.5) * 1.2 * mult;
            this.rotationSpeed = (Math.random() - 0.5) * 2;
        }

        this.rotation = 0;
        this.game.gameArea.appendChild(this.element);
    }

    // -------------------------------------------------------
    move() {
        this.vy += this.gravity;
        this.x  += this.vx;
        this.y  += this.vy;

        this.element.style.left = `${this.x}px`;
        this.element.style.top  = `${this.y}px`;

        if (this.isRocket) return;

        if (this.rotationSpeed !== 0) {
            this.rotation += this.rotationSpeed;
            this.element.style.transform = `rotate(${this.rotation}deg)`;
        }

        if (this.isLakitu || this.isEvilLakitu) {
            this.dropTimer++;
            if (this.dropTimer > 250) { this.dropItem(); this.dropTimer = 0; }
        }
    }

    // -------------------------------------------------------
    dropItem() {
        const img = this.isLakitu ? ASSETS.images.boshiPng : ASSETS.images.bombGif;
        const d   = new Target(img, this.game, true);
        d.x = this.x + 40;
        d.y = this.y + 40;
        this.game.targets.push(d);
    }

    // -------------------------------------------------------
    explode() {
        this.game.totalClicks++;
        if (this.game.totalClicks >= 100) unlockBadge('trigger_happy');

        let gamesPlayed = parseInt(localStorage.getItem('totalGamesPlayed') || 0);
        if (gamesPlayed >= 10) unlockBadge('game_marathon');

        if (!this.game.killWindow) this.game.killWindow = [];
        const now = Date.now();
        this.game.killWindow.push(now);
        this.game.killWindow = this.game.killWindow.filter(t => now - t < 8000);
        if (this.game.killWindow.length >= 15) unlockBadge('quad_kill');

        const rect    = this.element.getBoundingClientRect();
        const centerX = rect.left + rect.width  / 2;
        const centerY = rect.top  + rect.height / 2;
        const isGodMode = this.game.isInvulnerable;

        // ---- MODE FANTÔME ----
        if (this.element.classList.contains('ghost-mode')) {
            this.ghostClicks = (this.ghostClicks || 0) + 1;

            if (this.game.startTime) {
                const playDuration = (Date.now() - this.game.startTime) / 1000;
                if (playDuration >= 180) unlockBadge('time_master_3m');
            }

            if (this.game.lakituHitSound) { this.game.lakituHitSound.currentTime = 0; this.game.lakituHitSound.play(); }

            // Lakitu fantôme (gentil)
            if (this.isLakitu && !this.isEvilLakitu) {
                this.game.score += 100;
                this.showFloatingText('+100', rect.left, rect.top - 30, false, '#00FF00');

                const classicFlash = document.createElement('div');
                classicFlash.className = 'classic-flash-overlay';
                document.body.appendChild(classicFlash);
                setTimeout(() => classicFlash.remove(), 800);

                this.showFloatingText(`${this.ghostClicks}/8`, centerX, centerY, false, '#ffffff');

                if (this.ghostClicks === 8) {
                    this.dropTimer = -999999;
                    unlockBadge('SiV');
                    unlockBadge('inverse_mode');

                    this.game.timeLeft += 8;
                    this.game.isInverseMode = true;
                    document.body.style.boxShadow = 'inset 0 0 100px rgba(0, 255, 0, 0.5)';
                    this.showFloatingText('+8s & MODE INVERSE CUMULÉ !', rect.left, rect.top, false, '#00FF00');

                    if (this.game.inverseModeTimeout) clearTimeout(this.game.inverseModeTimeout);
                    this.game.inverseModeTimeout = setTimeout(() => {
                        this.game.isInverseMode = false;
                        document.body.style.boxShadow = '';
                        this.game.inverseModeTimeout = null;
                    }, 8000);

                    this.game.targets.forEach(t => { if (t.isBoshi || t.isDog || t.isStarUnicorn) t.remove(); });
                    this.remove();
                }
            }
            // Evil Lakitu fantôme
            else if (this.isEvilLakitu) {
                if (isGodMode) {
                    this.game.score += 100;
                    this.showFloatingText('+100', rect.left, rect.top - 30, false, '#00FF00');
                    if (this.game.godModeTimeout) clearTimeout(this.game.godModeTimeout);
                    this.game.godModeTimeout = setTimeout(() => {
                        this.game.isInvulnerable = false;
                        if (this.game.scoreElement) this.game.scoreElement.style.textShadow = '';
                        document.body.style.boxShadow = '';
                    }, 15000);
                } else {
                    this.game.score = Math.max(0, this.game.score - 100);
                    this.showFloatingText('-100', rect.left, rect.top - 30, true, '#ff0000');
                    const darkFlash = document.createElement('div');
                    darkFlash.className = 'evil-flash-overlay';
                    document.body.appendChild(darkFlash);
                    setTimeout(() => darkFlash.remove(), 800);
                }

                this.showFloatingText(`${this.ghostClicks}/??`, centerX, centerY, false, '#ffffff');

                if (this.ghostClicks === 10) {
                    this.dropTimer = -999999;
                    if (this.game.lakituEvilSound) { this.game.lakituEvilSound.currentTime = 0; this.game.lakituEvilSound.play(); }

                    let cloudCount = parseInt(localStorage.getItem('totalCloudsHit') || 0) + 1;
                    localStorage.setItem('totalCloudsHit', cloudCount);
                    if (cloudCount >= 25) unlockBadge('cloud_slayer');

                    this.game.score += 2500;
                    this.game.timeLeft += 15;
                    document.body.style.boxShadow = 'inset 0 0 100px rgba(255, 0, 0, 0.7)';
                    this.game.isInvulnerable = true;
                    if (this.game.scoreElement) this.game.scoreElement.style.textShadow = '0 0 20px #ff0000';
                    this.showFloatingText('+2500 PTS & IMMUNITÉ (15s)!', centerX, centerY, false, '#ff0000');

                    if (this.game.godModeTimeout) clearTimeout(this.game.godModeTimeout);
                    this.game.godModeTimeout = setTimeout(() => {
                        this.game.isInvulnerable = false;
                        if (this.game.scoreElement) this.game.scoreElement.style.textShadow = '';
                        document.body.style.boxShadow = '';
                    }, 15000);

                    unlockBadge('god_slayer');
                    unlockBadge('ghost_touch');
                    this.game.targets.forEach(t => t.convertToMalus());
                    this.remove();
                }
            }
            return;
        }

        // ---- COMPTEUR MALUS (badge Seigneur des Ombres) ----
        if (this.isKyurem || this.isBomb || this.isEvilLicorne || this.isRocket || this.isEvilLakitu) {
            this.game.sessionMalusHits = (this.game.sessionMalusHits || 0) + 1;
            if (this.game.sessionMalusHits >= 200) unlockBadge('shadow_god');
        }

        // ---- KYUREM ----
        if (this.isKyurem) {
            if (this.game.kyuremSound) { this.game.kyuremSound.currentTime = 0; this.game.kyuremSound.play(); }

            let dogCount = parseInt(localStorage.getItem('totalDogsCount') || 0) + 1;
            localStorage.setItem('totalDogsCount', dogCount);
            if (dogCount >= 7)  unlockBadge('tokyo_visitor');
            if (dogCount >= 20) unlockBadge('dog_god');

            if (isGodMode || this.game.isInverseMode) {
                this.game.score += 900;
                this.showFloatingText('+1500 PTS!', centerX, centerY, false, '#00FF00');
            } else {
                this.game.score = Math.max(0, this.game.score - 900);
                this.game.comboCount = 0;
                this.showFloatingText('-1500 DARKNESS!', centerX, centerY, true, '#ff0000');
                const dark = document.createElement('div');
                dark.className = 'darkness-overlay';
                document.body.appendChild(dark);
                setTimeout(() => { dark.style.opacity = '0'; setTimeout(() => dark.remove(), 1000); }, 2000);
            }
            this.createParticles(centerX, centerY, 'black');
            this.remove();
            return;
        }

        // ---- BOMBE ----
        else if (this.isBomb) {
            if (isGodMode || this.game.isInverseMode) {
                this.game.score += 320;
                this.showFloatingText('+320 PTS!', centerX, centerY, false, '#00FF00');
                this.createParticles(centerX, centerY, 'gold');
            } else {
                if (this.game.bombSound) { this.game.bombSound.currentTime = 0; this.game.bombSound.play(); }
                document.body.classList.add('screen-shake');
                setTimeout(() => document.body.classList.remove('screen-shake'), 500);
                this.game.score = Math.max(0, this.game.score - 320);
                this.game.comboCount = 0;
                this.showFloatingText('BOMBY -320!!', centerX, centerY, true);
                this.createParticles(centerX, centerY, 'black');
                unlockBadge('hit_bomb');
            }
            this.remove();
        }

        // ---- YAMI (Licorne Maléfique) ----
        else if (this.isEvilLicorne) {
            if (isGodMode || this.game.isInverseMode) {
                this.game.score += 250;
                this.showFloatingText('+250 PTS!', centerX, centerY, false, '#00FF00');
                this.createParticles(centerX, centerY, 'gold');
            } else {
                if (this.game.evilSound) { this.game.evilSound.currentTime = 0; this.game.evilSound.play(); }
                this.game.score = Math.max(0, this.game.score - 250);
                this.game.comboCount = 0;
                this.showFloatingText('CHEH -250!', centerX, centerY, true);
                this.createParticles(centerX, centerY, 'evil');

                let count = parseInt(localStorage.getItem('totalYami') || 0) + 1;
                localStorage.setItem('totalYami', count);
                if (count >= 20) unlockBadge('yami_eye');
                unlockBadge('yami_hunter');
            }
            this.remove();
        }

        // ---- LITIMES (Bonus temps) ----
        else if (this.isStarUnicorn) {
            if (this.game.guhaSound) { this.game.guhaSound.currentTime = 0; this.game.guhaSound.play(); }
            if (this.game.timeLeft < 3) unlockBadge('time_saver');

            this.game.timeLeft += 10;
            this.game.score    += 120;
            this.showFloatingText('TIME BONUS +10s!', centerX, centerY, false, '#FFD700');
            this.createParticles(centerX, centerY, '#FFD700');
            this.game.checkTimeAlert();
            unlockBadge('hit_litimes');
            this.remove();
        }

        // ---- BOSHI ----
        else if (this.isBoshi) {
            if (this.game.boshiSound) { this.game.boshiSound.currentTime = 0; this.game.boshiSound.play(); }
            this.game.score += 90;
            this.game.activateSuperCombo();
            this.showFloatingText('SUPER BOSHI!', centerX, centerY, false, '#0077ff');
            this.createParticles(centerX, centerY, '#0077ff');

            unlockBadge('hit_boshi');
            let count = parseInt(localStorage.getItem('totalBoshisCount') || 0) + 1;
            localStorage.setItem('totalBoshisCount', count);
            if (count >= 50)  unlockBadge('boshi_hunter');
            if (count >= 100) unlockBadge('boshi_god');
            this.remove();
        }

        // ---- LAKITU (Gentil) ----
        else if (this.isLakitu) {
            if (this.game.lakituSaveSound) { this.game.lakituSaveSound.currentTime = 0; this.game.lakituSaveSound.play(); }
            this.game.score += 480;
            this.game.boshiUnlocked = true;
            this.showFloatingText('LAKITU LOOT!', centerX, centerY, false, '#00FF00');
            this.createParticles(centerX, centerY, '#FFFFFF');
            this.spawnLoot(ASSETS.images.boshiPng,     centerX, centerY);
            this.spawnLoot(ASSETS.images.boshiPng,     centerX, centerY);
            this.spawnLoot(this.game.targetImages[0],   centerX, centerY);
            this.spawnLoot(this.game.targetImages[1],   centerX, centerY);
            this.spawnLoot(ASSETS.images.chienGif,     centerX, centerY);
            this.game.targets.forEach(t => { if (t.isBomb) t.convertToBonus(); });

            let count = parseInt(localStorage.getItem('totalCloudsHit') || 0) + 1;
            localStorage.setItem('totalCloudsHit', count);
            if (count >= 7) unlockBadge('laki_expert');
            unlockBadge('lakitu_slayer');

            this.element.classList.add('is-exploding');
            this.hp = Infinity;
            setTimeout(() => {
                this.element.classList.remove('is-exploding');
                this.element.style.pointerEvents = 'auto';
                this.hp = 1;
                this.element.classList.add('ghost-mode');
            }, 600);
            setTimeout(() => this.remove(), 30000);
        }

        // ---- EVIL LAKITU ----
        else if (this.isEvilLakitu) {
            if (this.game.lakituEvilSound) { this.game.lakituEvilSound.currentTime = 0; this.game.lakituEvilSound.play(); }
            this.game.score = Math.max(0, this.game.score - 550);
            this.showFloatingText('CHAOS & BOMBS!', centerX, centerY, true, '#FF0000');
            this.createParticles(centerX, centerY, 'evil');
            unlockBadge('hit_evil_lakitu');
            this.spawnLoot(ASSETS.images.kyuremGif, centerX, centerY);
            this.game.targets.forEach(t => t.convertToMalus());
            for (let i = 0; i < 3; i++) this.game.targets.push(new Target(ASSETS.images.licorne3evil, this.game));

            this.element.classList.add('is-exploding');
            this.hp = Infinity;
            setTimeout(() => {
                this.element.classList.remove('is-exploding');
                this.element.style.pointerEvents = 'auto';
                this.hp = 1;
                this.element.classList.add('ghost-mode');
            }, 600);
            setTimeout(() => this.remove(), 30000);
        }

        // ---- CHIEN (Tokyo) ----
        else if (this.isDog) {
            if (this.game.dogSound) { this.game.dogSound.currentTime = 0; this.game.dogSound.play(); }
            this.game.score += 1000;
            this.showFloatingText('EASTER EGG +1000!', centerX, centerY, false, '#00FF00');
            this.createParticles(centerX, centerY, '#00FF00');

            unlockBadge('dog_lover');
            let dogCount = parseInt(localStorage.getItem('totalDogsCount') || 0) + 1;
            localStorage.setItem('totalDogsCount', dogCount);
            if (dogCount >= 7)  unlockBadge('tokyo_visitor');
            if (dogCount >= 20) unlockBadge('dog_god');
            this.remove();
        }

        // ---- OVNI ----
        else if (this.isUFO) {
            if (this.game.ufoSound) { this.game.ufoSound.currentTime = 0; this.game.ufoSound.play(); }
            this.game.score += 180;
            this.showFloatingText('UFO +180!', centerX, centerY, false, '#00FFFF');
            this.createParticles(centerX, centerY, 'ufo');

            unlockBadge('ufo_slayer');
            let count = parseInt(localStorage.getItem('totalUfoCount') || 0) + 1;
            localStorage.setItem('totalUfoCount', count);
            if (count >= 20) unlockBadge('ufo_finder');
            if (count >= 55) unlockBadge('ufo_god');
            this.remove();
        }

        // ---- ROCKET ----
        else if (this.isRocket) {
            if (this.game.rocketHitSound) { this.game.rocketHitSound.currentTime = 0; this.game.rocketHitSound.play(); }
            this.game.sessionRockets = (this.game.sessionRockets || 0) + 1;
            if (this.game.sessionRockets >= 10) unlockBadge('rocket_legend');

            if (isGodMode || this.game.isInverseMode) {
                this.game.score += 450;
                this.showFloatingText('+450 PTS!', centerX, centerY, false, '#00FF00');
                this.createParticles(centerX, centerY, '#00FF00');
            } else {
                this.game.score = Math.max(0, this.game.score - 450);
                this.game.comboCount = 0;
                this.showFloatingText('ROCKET CRASH -450!', centerX, centerY, true, '#FF4500');
                document.body.classList.add('screen-shake');
                setTimeout(() => document.body.classList.remove('screen-shake'), 300);
                this.createParticles(centerX, centerY, '#FF4500');
            }
            this.remove();
        }

        // ---- CIBLES NORMALES ----
        else {
            unlockBadge('first_kill');
            if (!this.game.tappedTypes) this.game.tappedTypes = new Set();
            this.game.tappedTypes.add(this.element.src);
            if (this.game.tappedTypes.size >= 4) unlockBadge('hit_all_classics');

            const now2 = Date.now();
            if (now2 < this.game.comboFreezeUntil || now2 - this.game.lastHitTime < 800) {
                this.game.comboCount++;
                if (this.game.comboCount >= 10) unlockBadge('combo_10');
            } else {
                this.game.comboCount = 1;
            }
            this.game.lastHitTime = now2;

            const s = this.game.popSounds[Math.floor(Math.random() * this.game.popSounds.length)];
            if (s) { s.currentTime = 0; s.play(); }

            const pts = this.game.isSuperComboActive ? 50 : (25 * this.game.comboCount);
            this.game.score += pts;
            this.showFloatingText(`+${pts}`, centerX, centerY, false);
            this.createParticles(centerX, centerY, '#ff00ff');
            this.remove();
        }
    }

    // -------------------------------------------------------
    spawnLoot(img, x, y) {
        const loot = new Target(img, this.game, true);
        loot.x  = x;
        loot.y  = y;
        loot.vx = (Math.random() - 0.5) * 3;
        loot.vy = -1.5 - Math.random() * 1.5;
        this.game.targets.push(loot);
    }

    // -------------------------------------------------------
    convertToBonus() {
        if (this.isBomb) {
            this.isBomb = false;
            this.element.src       = this.game.targetImages[0];
            this.element.className = 'targets';
            this.element.style.width = '';
        }
    }

    // -------------------------------------------------------
    convertToMalus() {
        if (!this.isBomb && !this.isLakitu && !this.isEvilLakitu &&
            !this.isUFO  && !this.isDog    && !this.isKyurem) {
            this.isBomb          = true;
            this.element.src     = ASSETS.images.bombGif;
            this.element.className = 'targets bomb-target';
        }
    }

    // -------------------------------------------------------
    showFloatingText(t, x, y, m, c = null) {
        const d = document.createElement('div');
        d.className = m ? 'combo-text malus' : 'combo-text';
        d.textContent = t;
        if (c) d.style.color = c;
        d.style.left = `${x - 30}px`;
        d.style.top  = `${y}px`;
        document.body.appendChild(d);
        setTimeout(() => d.remove(), 800);
    }

    // -------------------------------------------------------
    createParticles(x, y, t) {
        const c = (t === 'ufo' || t === 'evil') ? 25 : 12;
        for (let i = 0; i < c; i++) {
            const p = document.createElement('div');
            p.className = 'pixel';
            p.style.backgroundColor = (t === 'ufo') ? '#00FFFF' : (t === 'evil' ? '#FF0000' : t);
            p.style.left = `${x}px`;
            p.style.top  = `${y}px`;
            const a    = (Math.PI * 2 / c) * i;
            const dist = 60 + Math.random() * 40;
            p.style.setProperty('--dx', Math.cos(a) * dist + 'px');
            p.style.setProperty('--dy', Math.sin(a) * dist + 'px');
            document.body.appendChild(p);
            setTimeout(() => p.remove(), 600);
        }
    }

    // -------------------------------------------------------
    remove() {
        if (this.element.parentNode) this.element.remove();
    }
}


// ============================================================
// BLOC JS 11 : INITIALISATION DE L'APPLICATION
// Lance la page d'accueil au chargement du DOM
// ============================================================
window.addEventListener('DOMContentLoaded', () => {
    showPage('page-accueil');
});

</script>


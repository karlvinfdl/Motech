            <circle cx="100" cy="100" r="48" fill="#ffffff"/>
            <text x="100" y="95" text-anchor="middle" font-size="14" font-weight="700" fill="#0b3a44">QUESTION /</text>
            <text x="100" y="115" text-anchor="middle" font-size="14" font-weight="700" fill="#0b3a44">REPONSE</text>
          </svg>
        </div>
        <button id="spin-wheel1" class="spin">JOUER</button>

  <label for="volumeSlider">🔊 Volume</label>
  <input type="range" id="volumeSlider" min="0" max="100" value="50">
  <span id="volumeValue">50%</span>
</div>

{# ================================================================
   PAGE INDEX — écran d'accueil (toujours visible)
   ================================================================ #}
<div id="page-index" class="page-layer active">
  <body class="intro">
    <main class="intro-layer">
      <section class="wheels" aria-label="Choix du mode de jeu">
        <a class="wheel wheel--quest" href="#" data-open="modal-wheel1">
          <img src="{{ asset('assets/images/Axel/questwheel.webp') }}" alt="Question / Réponse">

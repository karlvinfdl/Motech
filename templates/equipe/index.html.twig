            <polygon fill="#ffffff" points="27,16 27,28 5,28 5,16 7,16 7,14 9,14 9,12 11,12 11,10 13,10 13,8 15,8 15,6 17,6 17,8 19,8 19,10 21,10 21,12 23,12 23,14 25,14 25,16"></polygon>
            <rect width="8" height="2" x="18" y="7" fill="#000000" transform="rotate(90 22 8)"></rect>
            <rect width="5" height="5" x="18" y="19" fill="#000000"></rect>
            <polygon fill="#000000" points="29,14 29,16 25,16 25,14 23,14 23,12 21,12 21,10 19,10 19,8 17,8 17,6 15,6 15,8 13,8 13,10 11,10 11,12 9,12 9,14 7,14 7,16 3,16 3,14 5,14 5,12 7,12 7,10 9,10 9,8 11,8 11,6 13,6 13,4 15,4 15,2 17,2 17,4 19,4 19,6 21,6 21,8 23,8 23,10 25,10 25,12 27,12 27,14"></polygon>

{% extends 'base.html.twig' %}

{% block title %}Star Coaster - Accueil{% endblock %}

{% block stylesheets %}
    {# Ton fichier CSS unique qui contient tout le style assemblé #}
    <link rel="stylesheet" href="{{ asset('../image/Elodie/') }}">
{% endblock %}

{% block body %} 

<section id="game-viewportEM">
    <main class="hero-EM" id="menu-accueil">

        <div class="brand-EM">
            {# Image dans public/img/licorne.png #}
            <img src="{{ asset('img/licorne.png') }}" alt="Icone Wagon" class="brand-logo-EM">
        </div>

        <div class="hero-content-EM">
            {# Rappel : le fichier doit s'appeler tete-de-licorne-2.png dans public/img/ #}
            <img src="{{ asset('image/Elodie/licorne.png') }}" alt="Star Coaster Logo" class="hero-logo-EM">
        </div>

        <section class="glass-panel-EM">
            <p class="g-title-EM">Bienvenue dans le jeu des montagnes Russes !</p>
            <p class="g-mission-EM"><strong>Ta mission :</strong></p>
            <p class="g-text-EM">Guide la licorne jusqu'au bout du parcours...</p>
            <p class="g-text-EM">Attention : ne la laisse surtout pas tomber !</p>
        </section>

        {# Le bouton avec sa nouvelle classe suffixée #}
        <button class="bulle-jouer-EM" onclick="window.location.href='{{ path('app_game') }}'">
            JOUER
        </button>

    </main>

    {# Le canvas pour ton jeu avec sa classe suffixée si besoin dans le futur #}
    <canvas id="gameCanvas" class="canvas-game-EM" style="display:none;"></canvas>
     <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>
     <script src="{{ asset('montagnes.js') }}"></script>
</section>
{% endblock %}

 {% extends 'base.html.twig' %}

{% block title %}Star Coaster - Accueil & Jeu{% endblock %}

{% block body %}

    {# --- SYSTÈME DE NAVIGATION --- #}
    {% if app.request.query.get('page') != 'jeu' %}

        {# ========================================== #}
        {# 1. SECTION ACCUEIL - ORIGINAL              #}
        {# ========================================== #}
        <main class="hero-EM">
            {# LOGO 1 : Haut gauche #}
            <img src="{{ asset('assets/images/Elodie/licorne.png') }}" class="logo-top-left-EM">
            
            {# LOGO 2 : Central #}
            <img src="{{ asset('assets/images/Elodie/logostar.png') }}" alt="Logo principal" class="hero-logo-EM" width="280">
            
            <section class="glass-panel-EM">
                <p class="g-title-EM">Bienvenue dans le jeu des montagnes Russes !
                </p>
            
                <p><strong>Ta mission :</strong></p>
                <p>Guide la licorne jusqu'au bout du parcours...</p>
                <p>Attention : ne la laisse surtout pas tomber !</p>
                <p class="controls-hint-EM">ESPACE POUR SAUTER</p>
            </section>

            <div class="button-container-EM">
                <button class="bulle-jouer-EM" onclick="window.location.href='?page=jeu'">JOUER</button>
            </div>
        </main>

    {% else %}

        {# ========================================== #}
        {# 2. SECTION JEU - HUD BAS FIXE             #}
        {# ========================================== #}
        {# ========================================== #}
        {# 2. SECTION JEU - HUD BAS FIXE             #}
        {# ========================================== #}
        <div id="game-ui-wrapper-EM">
            <canvas id="gameCanvas"></canvas>

            {# HUD HAUT GAUCHE AVATAR + STATS VERTICAL #}
            <div id="hud-jeu-EM" class="pixel-hud-EM hud-top-left-EM">
                <div class="hud-avatar-section-EM">
                    <img src="{{ asset('assets/images/Elodie/licornee.png') }}" class="mini-avatar-EM" alt="Licorne">
                </div>
                <div class="hud-stats-vertical-EM">
                    <div class="hud-row-EM hud-stars-left-EM">
                        <img src="{{ asset('assets/images/Elodie/star1.png') }}" class="icon-hud-EM" alt="Stars">
                        <span id="val-stars">0</span>
                    </div>
                    <div class="hud-row-EM">
                        <div id="lives-container" class="hearts-row-EM"></div>
                    </div>
                    <div class="hud-row-EM">
                        <img src="{{ asset('assets/images/Elodie/heart1.png') }}" class="icon-hud-EM" alt="Coins">
                        <span id="val-coins">0</span>
                    </div>
                    <div class="hud-row-EM">
                        <span class="label-EM">NIVEAU</span>
                        <span id="level-display" class="value-EM">1</span>
                    </div>
                </div>
            </div>

            {# POP-UP DE FIN DE NIVEAU AVEC STATS #}
            <div id="end-screen-EM" class="overlay-EM" style="display: none;">
                <div class="glass-panel-EM">
                    <h1 id="stat-title-EM" style="color: #000000; margin-bottom: 20px;">NIVEAU RÉUSSI !</h1>
                    
                    <div style="display: flex; justify-content: center; gap: 30px; margin-bottom: 25px;">
                        <div style="text-align: center;">
                            <img src="{{ asset('assets/images/Elodie/heart1.png') }}" width="40" style="display: block; margin: 0 auto 5px;">
                            <span id="stat-coins-EM" style="font-size: 24px; font-weight: bold; color: #fff;">0</span>
                        </div>
                        <div style="text-align: center;">
                            <img src="{{ asset('assets/images/Elodie/star1.png') }}" width="40" style="display: block; margin: 0 auto 5px;">
                            <span id="stat-stars-EM" style="font-size: 24px; font-weight: bold; color: #fff;">0</span>
                        </div>
                    </div>

                    <div id="button-area-EM"></div>
                </div>
            </div>

            <script src="{{ asset('assets/script/coaster.js') }}" defer></script>
        </div>

    {% endif %}

{% endblock %}
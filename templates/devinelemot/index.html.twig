{% extends 'base.html.twig' %}

{% block title %}Devine le Mot - Jeu{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('assets/styles/app.css') }}">
{% endblock %}


{% block body %}
<div id="game-viewportAB">

    {# --- ÉTAPE 0 : ACCUEIL --- #}
    <section id="section-accueil" class="section-jeuAB active-AB">
        <div class="game-containerAB">
            <img src="{{ asset('assets/images/Alexis/titrefinal2.png') }}" alt="Devine le Mot" class="game-titleAB">
            <div class="btn-containerAB">
                <button class="blink-buttonAB">Press ESPACE pour commencer</button>
            </div>
        </div>
    </section>

    {# --- ÉTAPE 1 : RÈGLES --- #}
    {# CORRECTION : L'ID doit être section-regles pour correspondre au script JS #}
    <section id="section-regles" class="section-reglesAB page-reglesAB section-jeuAB">
        <div class="regles-wrapperAB">
            <div class="regles-cardAB">
                <div class="regles-sectionAB">
                    <h3 class="regles-titreAB">🎯 But du jeu</h3>
                    <p class="regles-texteAB">Devinez 6 mots pour sauver la licorne</p>
                </div>
                <div class="regles-sectionAB">
                    <h3 class="regles-titreAB">💡 Indices</h3>
                    <ul class="regles-listeAB">
                        <li class="regles-itemAB">Chaque mot a plusieurs indices.</li>
                        <li class="regles-itemAB">Vous pouvez cliquer sur “Autre indice” pour en changer.</li>
                    </ul>
                </div>
                <div class="regles-sectionAB">
                    <h3 class="regles-titreAB">❤️ Vies</h3>
                    <p class="regles-texteAB">Vous avez 3 vies. Vous perdez une vie si vous vous trompez ou si le temps est écoulé.</p>
                </div>
                <div class="regles-sectionAB">
                    <h3 class="regles-titreAB">⏱️ Temps</h3>
                    <p class="regles-texteAB">Vous avez 30 secondes par mot.</p>
                </div>
                <p class="instructionAB" style="text-align:center; margin-top:20px;">Press ESPACE pour jouer</p>
            </div>
        </div>
    </section>

    {# --- ÉTAPE 2 : LE JEU --- #}
    {# CORRECTION : L'ID doit être section-jeu pour correspondre au script JS #}
    <section id="section-jeu" class="section-jeuAB page-jeuAB">
        <header class="jeu-hudAB">
            <div class="vies-containerAB" id="vies-boxAB">
                <span class="coeurAB">❤️</span>
                <span class="coeurAB">❤️</span>
                <span class="coeurAB">❤️</span>
            </div>
            <div class="infos-topAB">
                <span id="timer-displayAB">30</span>
                <span class="stat-indiceAB" id="stat-indiceAB">Indice : 1/3</span>
                <span class="stat-progressionAB" id="stat-progressionAB">Mots restants : 6</span>
            </div>
        </header>

        <main class="ecran-splitAB">
            <section class="coteAB gaucheAB">
                <div class="personnage-containerAB">
                    <img src="{{ asset('assets/.gif/Alexis/licorne.gif') }}" alt="Licorne" class="pixel-spriteAB licorne-animAB">
                </div>
                <div class="interaction-zoneAB">
                    <div class="bulle-roseAB" id="bulle-indiceAB">Chargement...</div>
                    <button class="btn-retroAB" id="btn-passerAB">CHANGER D'INDICE</button>
                </div>
            </section>

            <section class="coteAB droiteAB">
                <div class="sorcier-containerAB">
                    <div class="bulle-dialogueAB" id="bulle-sorcierAB">Tu ne trouveras pas !</div>
                    <img src="{{ asset('assets/.gif/Alexis/Sorcier.gif') }}" id="image-sorcierAB" class="pixel-spriteAB">
                </div>
                <div class="interaction-zoneAB">
                    <input type="text" id="input-reponseAB" class="bulle-roseAB input-reponseAB" placeholder="Tape ta réponse..." autocomplete="off">
                    <div class="boutons-groupeAB">
                        <button class="btn-retroAB" id="btn-validerAB">VALIDER</button>
                        <button class="btn-retroAB" id="btn-passer-motAB">PASSER</button>
                    </div>
                </div>
            </section>
        </main>

        {# OVERLAYS #}
        <div id="overlay-game-overAB" class="overlay-ecranAB">
            <div class="overlay-contenuAB">
                <h1>GAME OVER</h1>
                <img src="{{ asset('assets/.gif/Alexis/Licorne qui pleure.gif') }}" class="licorne-mortAB">
                <p>Press ESPACE pour recommencer</p>
            </div>
        </div>

        <div id="overlay-you-winAB" class="overlay-ecranAB">
            <div class="overlay-contenuAB">
                <img src="{{ asset('assets/images/Alexis/écran victoire.png') }}" class="trophee-winAB">
                <p>Félicitations ! Le sorcier est vaincu.</p>
                <p class="instructionAB">Press ESPACE pour rejouer</p>
            </div>
        </div>
    </section>
</div>


<script>
/* -----------------------------------------------------
   GESTION DE LA NAVIGATION (MODALES)
----------------------------------------------------- */
let etapeActuelle = 0; 
// On récupère les éléments APRÈS le chargement du DOM pour être sûr
const sections = [
    document.getElementById('section-accueil'),
    document.getElementById('section-regles'),
    document.getElementById('section-jeu')
];

document.addEventListener("keydown", (event) => {
    if (event.code === "Space") {
        // Empêche le défilement si on n'est pas dans l'input
        if (event.target.tagName !== 'INPUT') {
            
            // Gestion des Overlays
            const gameOver = document.getElementById('overlay-game-overAB');
            const win = document.getElementById('overlay-you-winAB');

            if ((gameOver && gameOver.style.display === "flex") || 
                (win && win.style.display === "flex")) {
                window.location.reload();
                return;
            }

            // Navigation entre les étapes
            if (etapeActuelle < 2) {
                event.preventDefault();
                
                // On cache la section actuelle
                if(sections[etapeActuelle]) {
                    sections[etapeActuelle].classList.remove('active-AB');
                }

                etapeActuelle++;

                // On affiche la suivante
                if(sections[etapeActuelle]) {
                    sections[etapeActuelle].classList.add('active-AB');
                }

                // Initialisation du jeu si on arrive à l'étape 2
                if (etapeActuelle === 2) {
                    preparerPartie();
                    chargerMot();
                    demarrerTimer();
                    setTimeout(() => {
                         const input = document.getElementById('input-reponseAB');
                         if(input) input.focus();
                    }, 100);
                }
            }
        }
    }
});

/* -----------------------------------------------------
   LOGIQUE JEU (Le reste de ton code est identique)
----------------------------------------------------- */
const baseDeMots = {
    facile: [
        { mot: "internet", indices: ["Permet de se connecter au monde entier", "Sert à rechercher des informations", "Fonctionne avec le Wi-Fi ou la 4G/5G"] },
        { mot: "site web", indices: ["Se consulte avec un navigateur", "Contient des pages avec du texte et des images", "Peut présenter une entreprise ou vendre des produits"] },
        { mot: "application", indices: ["S’installe sur un téléphone ou un ordinateur", "Sert à faire une tâche précise", "On la télécharge sur un store"] },
        { mot: "email", indices: ["Permet d’envoyer un message en ligne", "Peut contenir des pièces jointes", "A besoin d’une adresse (ex : nom@gmail.com)"] },
        { mot: "mot de passe", indices: ["Protège un compte", "Doit rester secret", "Contient souvent des lettres et des chiffres"] },
        { mot: "wifi", indices: ["Permet d’avoir Internet sans fil", "Fonctionne avec une box", "Nécessite un code pour se connecter"] },
        { mot: "video", indices: ["Image en mouvement", "Peut avoir du son", "Se regarde sur un écran"] },
        { mot: "photo", indices: ["Image fixe", "Prise avec un téléphone ou un appareil", "Peut être partagée en ligne"] },
        { mot: "reseau social", indices: ["Permet de communiquer avec d’autres personnes", "On peut publier du contenu", "On peut aimer et commenter"] },
        { mot: "telechargement", indices: ["Permet de récupérer un fichier", "Vient d’Internet vers ton appareil", "Processus de réception de données"] }
    ],
    moyen: [
        { mot: "navigateur", indices: ["Permet d’aller sur des sites web", "On l’ouvre pour faire une recherche Google", "Logiciel comme Chrome ou Firefox"] },
        { mot: "cloud", indices: ["Permet de garder des fichiers en ligne", "Accessible depuis plusieurs appareils", "Évite de tout stocker sur son PC"] },
        { mot: "stockage", indices: ["Sert à garder des fichiers", "Capacité mesurée en Go ou To", "Mémoire de l'appareil"] },
        { mot: "streaming", indices: ["Regarder une vidéo sans télécharger", "Flux de données en direct", "Utilisé par Netflix ou YouTube"] },
        { mot: "mise a jour", indices: ["Améliore un logiciel", "Corrige des bugs", "Indispensable pour la sécurité"] },
        { mot: "algorithme", indices: ["Suite d'instructions mathématiques", "Utilisé par les réseaux sociaux", "Décide de ce que vous voyez"] }
    ],
    difficile: [
        { mot: "interface", indices: ["Ce que l’on voit à l’écran", "Zone d'interaction utilisateur", "Le 'I' dans UI"] },
        { mot: "base de donnee", indices: ["Sert à stocker beaucoup d’infos", "Structure SQL ou NoSQL", "Le cerveau de stockage d'un site"] },
        { mot: "automatisation", indices: ["Exécuter des tâches sans humain", "Fait gagner du temps", "Robotisation logicielle"] },
        { mot: "securite informatique", indices: ["Protège les données", "Lutte contre les cyberattaques", "Aussi appelée cybersécurité"] }
    ]
};

let listeDeJeu = [];
let motsTrouvesCompteur = 0; 
let indiceActuelIndex = 0; 
let vies = 3;
let temps = 30;
let timer;

function preparerPartie() {
    const faciles = [...baseDeMots.facile].sort(() => 0.5 - Math.random()).slice(0, 3);
    const moyens = [...baseDeMots.moyen].sort(() => 0.5 - Math.random()).slice(0, 2);
    const difficiles = [...baseDeMots.difficile].sort(() => 0.5 - Math.random()).slice(0, 1);
    listeDeJeu = [...faciles, ...moyens, ...difficiles];
}

function chargerMot() {
    if (listeDeJeu.length === 0) {
        afficherVictoire();
        return;
    }
    indiceActuelIndex = 0; 
    actualiserAffichageIndice();
    document.getElementById('stat-progressionAB').textContent = `Mots restants : ${listeDeJeu.length}`;
    temps = 30;
    document.getElementById('timer-displayAB').textContent = temps;
}

function actualiserAffichageIndice() {
    const data = listeDeJeu[0];
    document.getElementById('bulle-indiceAB').textContent = "Indice : " + data.indices[indiceActuelIndex];
    document.getElementById('stat-indiceAB').textContent = `Indice : ${indiceActuelIndex + 1}/3`;
}

function changerIndice() {
    indiceActuelIndex = (indiceActuelIndex + 1) % 3;
    actualiserAffichageIndice();
}

function passerMot() {
    if (listeDeJeu.length > 1) {
        const motActuel = listeDeJeu.shift(); 
        listeDeJeu.push(motActuel); 
        chargerMot();
        document.getElementById('input-reponseAB').value = "";
    }
}

function demarrerTimer() {
    if (timer) clearInterval(timer);
    timer = setInterval(() => {
        temps--;
        document.getElementById('timer-displayAB').textContent = temps;
        if (temps <= 0) {
            penaliteVie();
        }
    }, 1000);
}

function verifierReponse() {
    const input = document.getElementById('input-reponseAB');
    const reponseJoueur = input.value.trim().toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    const motCorrect = listeDeJeu[0].mot.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    
    if (reponseJoueur === motCorrect) {
        listeDeJeu.shift(); 
        motsTrouvesCompteur++;
        const imageSorcier = document.getElementById('image-sorcierAB');
        let progression = motsTrouvesCompteur / 6; 
        imageSorcier.style.filter = `grayscale(${progression * 100}%)`;
        imageSorcier.style.opacity = 1 - (progression * 0.8); 
        input.value = "";
        chargerMot(); 
    } else {
        penaliteVie();
        input.value = "";
    }
}

function penaliteVie() {
    vies--;
    actualiserVies();
    if (vies <= 0) {
        finDePartie("GAME OVER");
    } else {
        const motEnEchec = listeDeJeu.shift();
        listeDeJeu.push(motEnEchec);
        chargerMot();
    }
}

function actualiserVies() {
    const coeurs = document.querySelectorAll('.coeurAB');
    if (vies >= 0 && vies < 3) {
        coeurs[vies].style.opacity = "0.2";
        coeurs[vies].style.filter = "grayscale(1)";
    }
}

function afficherVictoire() {
    clearInterval(timer);
    document.getElementById('overlay-you-winAB').style.display = "flex";
}

function finDePartie(message) {
    clearInterval(timer);
    document.getElementById('overlay-game-overAB').style.display = "flex";
}

// Events boutons
document.getElementById('btn-validerAB').onclick = verifierReponse;
document.getElementById('btn-passerAB').onclick = changerIndice; 
document.getElementById('btn-passer-motAB').onclick = passerMot;
document.getElementById('input-reponseAB').onkeypress = (e) => { if (e.key === 'Enter') verifierReponse(); };
</script>
{% endblock %}